@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject AppState State


@code {
    private string? Code;

    protected override void OnInitialized()
    {
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        Code = query.Get("code");

    }

    private string Link(string baseUrl)
    {
        if (string.IsNullOrWhiteSpace(Code))
            return baseUrl;

        // code anfügen
        return $"{baseUrl}?code={Code}";
    }
}
<meta charset="utf-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
        <base href="/"/>
        <link rel="stylesheet" href="css/bootstrap/bootstrap.min.css"/>
        <link rel="stylesheet" href="app.css"/>
        <link rel="stylesheet" href="Worktrack.styles.css"/>
        <link rel="icon" type="image/png" href="favicon.png?v=2"/>
        <script src="_framework/blazor.web.js"></script>

    <script src="/_framework/aspnetcore-browser-refresh.js"></script>
    <ToastHost/>
<div class="layout">
    <header>
        <a href="/">
            <img src="/images/clubwork.png" alt="Clubwork logo" width="70" height="70" style="display:block;" />
        </a>

        <nav>
            <a href="/user/login">User Login</a>
            <a href="@Link("/user/dashboard")">Dashboard</a>
            @if(State.CurrentUser?.Role == "admin"){
            <a href="@Link("/admin/dashboard")">Admin</a>}
        </nav>

    </header>

    <main class="container">
        @Body
    </main>
   
    <footer>
        © @(DateTime.Now.Year) Worktrack – All rights reserved.
        <a href="/impressum">Impressum</a> · 
        <a href="/datenschutz">Datenschutz</a>
    </footer>
    
</div>
