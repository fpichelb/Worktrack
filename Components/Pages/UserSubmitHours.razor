@page "/user/submit-hours"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@inject ToastService Toast
@inject NavigationManager Nav
@inject AppDbContext Db

@rendermode InteractiveServer

<h2 class="title">Arbeitsstunden einreichen</h2>
<p class="subtitle">Hallo @CurrentUser?.Name <br> Trage hier deine geleisteten Stunden ein. Wähle dazu das passende Event aus.</p>

<div class="card">

    @foreach (var row in Rows)
    {
        <div class="multi-row-5">

            <select class="input" @bind="row.EventId">

                <option value="-1">---Auswählen---</option>
                @foreach (var ev in Events)
                {
                    <option value="@ev.Id">@ev.Name</option>
                }
            </select>

            <input type="date" class="input" @bind="row.Date" />

            <input type="number" step="0.25" class="input" placeholder="Stunden" @bind="row.Hours" />

            <input type="text" class="input" placeholder="Beschreibung" @bind="row.Description" />

            <button class="btn-remove" @onclick="@(() => RemoveRow(row))">✕</button>
        </div>
    }

    <button class="btn-add" @onclick="AddRow">+ Eintrag hinzufügen</button>
    <button class="btn primary" @onclick="Submit">Einreichen</button>
</div>

@code {
    public class UserHourEntryInput
    {
        public int? EventId { get; set; }
        public DateTime Date { get; set; } = DateTime.Today;
        public double Hours { get; set; }
        public string Description { get; set; } = "";
    }

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;
    private List<UserHourEntryInput> Rows = new();
    private List<Event> Events = new();
    private User? CurrentUser;
    private bool _loaded;
    private string UserLoginUrl="/user/login";

    protected override async Task OnParametersSetAsync()
    {
    if (_loaded)
    return;

    if (AuthenticationStateTask is null){
        return;
    }   
    var auth = await AuthenticationStateTask;
    if (auth.User.Identity?.IsAuthenticated != true){
        Nav.NavigateTo(UserLoginUrl);
        return;
    }
    var userId = auth.User.FindFirst("UserId")?.Value;
    if (userId is null){
        Nav.NavigateTo(UserLoginUrl);
        return;
        }

    CurrentUser = await UService.GetUserByStringId(userId);
    if (CurrentUser is null)
        return;
    _loaded = true; 
        Events = await Db.Events
        .Where(e => !e.IsArchived)
        .OrderBy(e => e.Name)
        .ToListAsync();

        AddRow();
    }

    void AddRow() => Rows.Add(new UserHourEntryInput());

    void RemoveRow(UserHourEntryInput row) => Rows.Remove(row);

    private async Task Submit()
    {
        if (!Rows.Any(r => r.EventId > 0))
        {
            Toast.ShowWarning("Fehler beim Stunden einreichen", "Bitte wähle für alle Zeilen ein Event aus.");
            return;
        }
        if (!Rows.Any(r => r.Hours > 0))
        {
            Toast.ShowWarning("Fehler beim Stunden einreichen", "Bitte mindestens einen Eintrag ausfüllen.");
            return;
        }

        foreach (var r in Rows)
        {
            var entry = new TimeEntry
            {
                UserName = "",
                NameEntered = CurrentUser?.Name??"",
                Status = "pending_assignment",
                EventId = r.EventId ?? 1,
                DurationHours = r.Hours,
                CheckIn = r.Date,
                CheckOut = DateTime.UtcNow,
                Task = r.Description,
            };

            Db.TimeEntry.Add(entry);
        }

        await Db.SaveChangesAsync();

        Toast.ShowSuccess("Stunden einreichen", "Stunden erfolgreich eingereicht!");

        Rows.Clear();
        AddRow();
    }
}
