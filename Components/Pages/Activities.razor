@page "/activities"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Worktrack.ViewModels
@attribute [Authorize]

@inject ActivityService ActivityService
@inject ToastService Toast
@inject NavigationManager Nav

<h3 class="card">Aktivitäten</h3>

@if (_isLoading)
{
    <div class="d-flex align-items-center gap-2">
        <div class="spinner-border" role="status" aria-hidden="true"></div>
        <span class="text-muted">Lade Daten…</span>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3">
        <!-- Liste -->
        <div class="col-12 col-lg-5">
            <div class="card">
                <div class="card-header d-flex align-items-center justify-content-between py-1 px-3">
                    <span class="small fw-semibold">Übersicht</span>

                    <div class="d-flex align-items-center gap-4">
                        <button class= " btn-background-none py-1" @onclick="()=>_showFilter=!_showFilter"> Filter ▼</button>
                        <button class="btn btn-primary" style="max-width:115px;" @onclick="Reload">
                            Neu laden
                        </button>
                    </div>
                </div>
                @if(_showFilter){
                <div class="position-absolute bg-light border rounded shadow p-3" style="z-index: 999; right:20px; top:70px;">
                            <label class="text-end p-0 m-0">
                            <button class=" btn-remove btn-background-none p-0 m-0" @onclick="(()=>_showFilter=false)">✕</button>
                            </label>
                            <label class="form-check form-switch mb-0 small mt-0">
                                <input class="form-check-input" type="checkbox" @bind="_filterRegistered" />
                                Angemeldet
                            </label>

                            <label class="form-check form-switch mb-0 small mt-0">
                                <input class="form-check-input" type="checkbox" @bind="_filterNext14Days" />
                                in 14 Tagen
                            </label>
                            <label class="form-check form-switch mb-0 small mt-0">
                                <input class="form-check-input" type="checkbox" @bind="_sortByGroups" />
                                nach Gruppen Sortieren
                            </label>
                            <label>Nur eine Gruppe anzeigen
                            <select class="form-select form-select-sm"  @bind="_filterGroupId">
                            <option value="-1">Alle Gruppen</option>
                            @foreach (var g in _groups)
                            {
                                <option value="@g.Id">@g.Name</option>
                            }
                            
                 </select>
                </label>
                </div>
                }
                <div class="list-group list-group-flush">
                    @if(_sortByGroups){
                        @foreach (var grp in FilteredActivities
                            .SelectMany(a => a.GroupNames.DefaultIfEmpty("(Ohne Gruppe)"),
                                        (a, g) => new { Activity = a, Group = g })
                            .GroupBy(x => x.Group))
                        {
                            <h5 class="mt-4 mb-2 text-muted">@grp.Key</h5>

                            <div class="list-group">

                                @foreach (var item in grp)
                                {
                                    var active = _selected?.Id == item.Activity.Id;
                                    <button type="button" href="#selectedEvent" class="list-group-item list-group-item-action @(active ? "active" : "")"
                                        @onclick="() => Select(item.Activity.Id)">
                                        <a class="position-absolute " style="width:100%; height:100%;"href="/activities/#selectedEvent"></a>
                                        <div class="d-flex justify-content-between">
                                            <div>
                                                <div class="fw-semibold">@item.Activity.Name</div>
                                                <div class="small text-muted">@item.Activity.Ort</div>
                                            </div>
                                            <div class="text-end small">
                                                @if (item.Activity.MaxTeilnehmer > 0)
                                                {
                                                    <div>@item.Activity.ActiveCount/@item.Activity.MaxTeilnehmer</div>
                                                }
                                                else
                                                {
                                                    <div>@item.Activity.ActiveCount</div>
                                                }
                                                @if (item.Activity.EmpfohleneTeilnehmer > 0)
                                                {
                                                    <div class="text-muted">empf. @item.Activity.EmpfohleneTeilnehmer</div>
                                                }
                                            </div>
                                        </div>
                                    </button>
                                }
                            </div>
                        }
                    }else{
                        @foreach (var a in FilteredActivities)
                        {
                            var active = _selected?.Id == a.Id;
                            
                            <button type="button"   class="list-group-item list-group-item-action @(active ? "active" : "")"
                                @onclick="() => Select(a.Id)">
                                <a class="position-absolute " style="width:100%; height:100%;"href="/activities/#selectedEvent"></a>
                                <div class="d-flex justify-content-between" >
                                
                                    <div>
                                        <div class="fw-semibold">@a.Name</div>
                                        <div class="small text-muted">@a.Ort</div>
                                    </div>
                                    <div class="text-end small">
                                        @if (a.MaxTeilnehmer > 0)
                                        {
                                            <div>@a.ActiveCount/@a.MaxTeilnehmer</div>
                                        }
                                        else
                                        {
                                            <div>@a.ActiveCount</div>
                                        }
                                        @if (a.EmpfohleneTeilnehmer > 0)
                                        {
                                            <div class="text-muted">empf. @a.EmpfohleneTeilnehmer</div>
                                        }
                                    </div>
                                </div>
                                
                            </button>
                            
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Details + Aktionen -->
        <div class="col-12 col-lg-7">
            @if (_selected is null)
            {
                <div class="alert alert-info mb-0">Wähle eine Aktivität aus.</div>
            }
            else
            {
                <div class="card" id="selectedEvent">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            @if(!string.IsNullOrWhiteSpace(_selected.ContentType)){
                                <div style="margin-right:20px;max-width:25%">
                                <button type="button" class="p-0 border-0 bg-transparent "
                                        @onclick="() => OpenModal()">
                                    <img src="@ToDataUrl(_selected.ContentType, _selected.Data)" class="img-thumbnail"
                                        style="width: 140px; height: 100px; object-fit: cover;" />
                                </button>
                                </div>
                            }
                            <div style="max-width: 55%;">
                                <h4 class="mb-1">@_selected.Name</h4>
                                <div class="text-muted">@_selected.Ort</div>
                            </div>

                            <div class="text-end">
                                @if (_selected.MaxTeilnehmer > 0)
                                {
                                    <div class="badge bg-secondary">

                                        @_selected.ActiveCount / @_selected.MaxTeilnehmer
                                    </div>
                                }
                                else
                                {
                                    <div class="badge bg-secondary">@_selected.ActiveCount / ∞</div>
                                }

                                @if (_selected.LastUnregistrationAt is not null)
                                {
                                    <div class="small text-muted mt-1">
                                        @_selected.Datum.ToShortDateString()
                                        <br>
                                        Abmeldung bis:
                                        @_selected.LastUnregistrationAt.Value.ToLocalTime().ToString("dd.MM.yyyy")
                                        

                                    </div>
                                }
                            </div>
                        </div>

                        <hr />

                        <p class="mb-3">@_selected.Info</p>
                        
                        <div class="d-inline gap-2  ">
                            @if (_isRegistered)
                            {   
                                <div class="row m-0 justify-content-between">
                                <div class="col-auto p-0">
                                <button class="btn btn-remove " disabled="@_busy" @onclick="Unregister">
                                    Abmelden
                                </button></div>
                                <div class="col-5 d-flex">
                                <p class="text-muted col-6 mb-0 mt-2 me-3 text-end"style="font-size:11px;">Extra <br />Gäste</p>
                                
                                <InputNumber class ="col-6 text-right" min="0"
                                            step="1" 
                                            @bind-value=_selected.Extra @bind-value:after="()=>UpdateExtra()"/>
                                </div>
                                </div>
                            }
                            else
                            {
                                <button class="btn btn-primary " disabled="@RegistrationDisabled" @onclick="Register">
                                    Anmelden
                                </button>
                                <p class="text-muted small mt-1" > Du musst dich erst zur Aktivität anmelden,<br />bevor du Extra Gäste angeben kannst.</p>
                            }

                            @if ((_selected.ActiveCount >= _selected.MaxTeilnehmer &&
                                                !_isRegistered) && !(_selected.MaxTeilnehmer == 0))
                            {
                                <span class="text-muted align-self-center">Maximale Teilnehmerzahl erreicht</span>
                            }
                        </div>

                        <hr />

                        <h5 class="mb-2">Angemeldet</h5>
                        @if (_selected.Participants.Count == 0)
                        {
                            <div class="text-muted">Noch niemand angemeldet.</div>
                        }
                        else
                        {
                            <ul class="list-group">
                                @foreach (var p in _selected.Participants)
                                {
                                    
                                    <div class="list-group-item multi-row-2 d-flex p-1" >
                                     
                                        <div class="col-6 small">@p.DisplayName +@p.Extra</div>
                                        <div class="col-5 text-muted small text-end">@p.RegisteredAt.ToLocalTime().ToString("dd.MM HH:mm")</div>
                                    <AuthorizeView Roles="admin,actManager">
                                        <button class="btn-remove ms-3 p-auto" @onclick="()=>UnregisterAdmin(p.UserId)">✕</button>
                                    </AuthorizeView> 
                                    </div>
                                    
                                }
                            </ul>
                        }
                        <AuthorizeView Roles="admin,actManager">
                        
                            <div class="row g-2 align-items-end">
                                <div class="col">
                                    <label class="form-label small mb-1">
                                        User suchen <span class="text-muted">(Admin)</span>
                                    </label>
                                    <input class="form-control form-control-sm"
                                           placeholder="Name eingeben…"
                                           value="@_userQuery"
                                           @oninput="OnUserQueryInput" />
                                </div>

                                <div class="col-auto">
                                    <label class="form-label small mb-1 text-muted">
                                        Extra Gäste
                                    </label>
                                    <input type="number"
                                           class="form-control form-control-sm"
                                           style="width: 90px;"
                                           min="0"
                                           step="1"
                                           @bind="adminExtra" />
                                </div>
                            </div>
                            
                            <!-- Select -->
                            <label class="form-label mt-3">Treffer</label>
                            <select class="form-select" @bind="_selectedUserId" disabled="@(_userHits.Count == 0)">
                                <option value="">– User auswählen –</option>

                                @foreach (var u in _userHits)
                                {
                                    <option value="@u.Id">
                                        @u.Name
                                    </option>
                                }
                            </select>
                            <!-- Aktion -->
                            <div class="mt-3">
                                <button class="btn btn-primary" disabled="@(_busy || _selectedUserId is null)"
                                    @onclick="RegisterAdmin">
                                    Zum Event anmelden
                                </button>
                            </div>

                            @if (_searchBusy)
                            {
                                <div class="text-muted mt-2">
                                    <span class="spinner-border spinner-border-sm"></span>
                                    Suche…
                                </div>
                            }
                            <div class="form-text">
                                Tippe mindestens 2 Zeichen. Top 10 Treffer erscheinen darunter.
                            </div>

                        </AuthorizeView>
                    </div>
                </div>
            }

            <!-- Admin-Block: Erstellen/Bearbeiten -->
            <AuthorizeView Roles="admin,actManager">
                <div class="card mt-3">
                    <div class="card-header">Admin</div>
                    <div class="card-body">
                        <h5 class="mb-3">Neue Aktivität</h5>
                            
                            <div class="row g-2">
                            <div class="col-md-6">
                                <label class="form-label">Name</label>
                                <input class="form-control" @bind="_new.Name" />
                                <label class="form-label">Ort</label>
                                <input class="form-control" @bind="_new.Ort" />
                            </div>
                            <div class="col-md-6">
                                 <label class="form-label mt-3">Gruppen</label>

                                <select class="form-select form-select-sm" multiple size="5"
                                          @onchange="OnGroupsChanged">
                                    @foreach (var g in _groups)
                                    {
                                        <option value="@g.Id" selected="@(_editGroupIds.Contains(g.Id))">
                                            @g.Name
                                        </option>
                                    }
                                  </select>
                                  <div class="d-flex">
                                  <button class="btn btn-outline-success m-0 p-1 " style="max-width:40px; max-height:40px;" type="button" title="Gruppe hinzufügen"
                                                  @onclick="OpenAddGroup">
                                              +
                                          </button>

                                          <button class="btn btn-remove m-0 p-1 " style="max-width:40px; max-height:40px;" type="button" title="Gruppe löschen"
                                                  disabled="@(!_editGroupIds.Any())"
                                                  @onclick="DeleteSelectedGroup">
                                              −
                                          </button>
                                  <div class="form-text">Mehrfachauswahl: Ctrl/⌘ oder antippen.</div>
                                                          </div>
                                                          </div>
                                                          @if (_showAddGroup)
                                      {
                                          <div class="input-group position-absolute z-100 bg-light border rounded shadow p-4">
                                              <input class="form-control" placeholder="Neue Gruppe…" @bind="_newGroupName" />
                                              <button class="btn btn-success" type="button" @onclick="AddGroup">OK</button>
                                              <button class="btn btn-outline-secondary" type="button" @onclick="CancelAddGroup">Abbrechen</button>
                                          </div>
                                      }
                            <div class="col-md-6">
                                <label>Datum</label>
                                <input type="date" class="form-control" @bind="@_new.Datum" />
                                <label>Deadline zum Austragen</label>
                                <input type="datetime-local" class="form-control" @bind="@_new.UnregisteredAt" />
                            </div>
                            <div class="col-md-6 text-center">
                            @if (!string.IsNullOrWhiteSpace(_previewDataUrl))
                            {
                                    
                                    <div class="text-muted small mb-1">Vorschau</div>
                                    <img src="@_previewDataUrl" class="img-thumbnail" style="max-height: 180px;" />
                            
                            }
                            </div>
                            <div class="col-12">
                            <label>Bild (optional)</label>
                            <InputFile OnChange="OnFileSelected" accept="image/*"  />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Info</label>
                                <textarea class="form-control" rows="4" @bind="_new.Info"></textarea>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Maximale Teilnehmer</label>
                                <input class="form-control" type="number" @bind="_new.MaxTeilnehmer" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Empfohlene Teilnehmer</label>
                                <input class="form-control" type="number" @bind="_new.EmpfohleneTeilnehmer" />
                            </div>
                            <div class="col-md-6">
                                <button class="btn btn-success" disabled="@_busy" @onclick="Create">
                                    Erstellen
                                </button>
                            </div>
                            @if (_selected is not null)
                            {
                                <button class="btn btn-outline-secondary" disabled="@_busy" @onclick="LoadSelectedIntoEditor">
                                    Ausgewählte zum Bearbeiten laden
                                </button>
                            }
                            @if (_selectedLoaded)
                            {
                                <button class="btn btn-outline-secondary" disabled="@_busy" @onclick="Save">
                                    Änderung speichern
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </AuthorizeView>
        </div>
        @if (_showModal && _selected is not null)
            {
                <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,.5);">
                    <div class="modal-dialog modal-lg modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">@_selected.FileName</h5>
                                <button type="button" class="btn-close" @onclick="CloseModal"></button>
                            </div>
                            <div class="modal-body">
                                <img src="@ToDataUrl(_selected.ContentType, _selected.Data)"
                                     class="img-fluid rounded" />
                            </div>
                        </div>
                    </div>
                </div>
            }
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private bool _isLoading = true;
    private bool _busy;
    private string? _error;
    private string _userQuery = "";
    private bool _searchBusy;
    private int? _selectedUserId;
    private int adminExtra;
    private List<User> _userHits = new();
    private List<ActivityGroupVm> _groups = new();
    private CancellationTokenSource? _searchCts;
    private int _currentUserId;
    private int oldextra;
    private List<ActivityListItemVm> _activities = new();
    private ActivityDetailVm? _selected;
    private int _selectedId;
    private bool _selectedLoaded=false;
    private bool _isRegistered;
    private bool isFull => _selected is not null && _selected.MaxTeilnehmer > 0 && _selected.ActiveCount >=
    _selected.MaxTeilnehmer;
    private bool RegistrationDisabled => _busy || isFull;
    private IBrowserFile? _selectedFile;
    private string? _previewDataUrl;
    private bool _showModal;
    private bool _showFilter;
    private bool _filterRegistered;
    private bool _filterNext14Days;
    private int _filterGroupId =-1;
    private bool _sortByGroups;
    private List<int> _editGroupIds = new(); // aktuelle Auswahl für die Aktivität
    private bool _showAddGroup;
    private string _newGroupName = "";
    private IEnumerable<ActivityListItemVm> FilteredActivities
    {
        get
        {
            IEnumerable<ActivityListItemVm> q = _activities;

            if (_filterGroupId !=-1)
            q = q.Where(a => a.GroupIds.Contains(_filterGroupId));

            if (_filterRegistered)
                q = q.Where(a => a.IsRegistered);

            if (_filterNext14Days)
            {
                var now = DateTime.Now;
                var until = now.AddDays(14);
                q = q.Where(a =>  a.Datum <= until);
            }

            return q.OrderByDescending(a => a.Datum);
        }
    }

    private ActivityCreateVm _new = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadUserId();
        _groups = await ActivityService.GetGroupsAsync();
        await Reload();
        _new.Datum = DateTime.Today;
        _new.UnregisteredAt = DateTime.Today;
    }
    private void OpenAddGroup() => _showAddGroup = true;
    private void CancelAddGroup() { _showAddGroup = false; _newGroupName = ""; }

    private void OnGroupsChanged(ChangeEventArgs e)
    {
        // Blazor liefert hier je nach Browser/Framework string oder string[]
        if (e.Value is string s)
        {
            // manchmal kommt "1,2,3" oder "1"
            _editGroupIds = s.Split(',', StringSplitOptions.RemoveEmptyEntries)
                             .Select(x => int.TryParse(x, out var v) ? v : (int?)null)
                             .Where(x => x.HasValue).Select(x => x!.Value).ToList();
            return;
        }

        if (e.Value is IEnumerable<string> arr)
        {
            _editGroupIds = arr.Select(x => int.TryParse(x, out var v) ? v : (int?)null)
                               .Where(x => x.HasValue).Select(x => x!.Value).ToList();
        }
    }

    private async Task AddGroup()
    {
        var (ok, error, id) = await ActivityService.AddGroupAsync(_newGroupName);
        if (!ok) { Toast.ShowWarning("Achtung",error ?? "Nicht möglich."); return; }

        Toast.ShowSuccess("Erfolg","Gruppe angelegt.");
        _showAddGroup = false;
        _newGroupName = "";

        _groups = await ActivityService.GetGroupsAsync();
    }

    private async Task DeleteSelectedGroup()
    {
        if (_editGroupIds is null) return;

        var (ok, error) = await ActivityService.DeleteGroupAsync(_editGroupIds.FirstOrDefault());
        if (!ok) { Toast.ShowWarning( "Achtung", error ?? "Nicht möglich."); return; }

        Toast.ShowSuccess("Erfolg","Gruppe gelöscht.");
        _editGroupIds.Clear();
        _groups = await ActivityService.GetGroupsAsync();
    }
    private async Task LoadUserId()
    {
        if (AuthenticationStateTask is null) return;

        var auth = await AuthenticationStateTask;
        var userIdStr = auth.User.FindFirst("UserId")?.Value;
        if (!int.TryParse(userIdStr, out _currentUserId))
            _currentUserId = 0;
    }
    private async Task OnUserQueryInput(ChangeEventArgs e)
{
    _userQuery = e.Value?.ToString() ?? "";

    _selectedUserId = null;
    _userHits.Clear();

    if (_userQuery.Trim().Length < 2)
        return;

    _searchCts?.Cancel();
    _searchCts = new CancellationTokenSource();
    var ct = _searchCts.Token;

    _searchBusy = true;

    try
    {
        await Task.Delay(300, ct); // Debounce
        _userHits = await UService.GetBestUsers(_userQuery.Trim(), 10, ct);
    }
    catch (OperationCanceledException) { }
    catch (Exception ex)
    {
        Toast.ShowError("Achtung",ex.Message);
    }
    finally
    {
        _searchBusy = false;
        await InvokeAsync(StateHasChanged);
    }
}

    private async Task Reload()
    {
        _isLoading = true;
        _error = null;
        try
        {
            _activities = await ActivityService.GetListAsync(_currentUserId);
            _selected = null;
            _isRegistered = false;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task Select(int id)
    {
        _busy = true;
        try
        {
            _selected = await ActivityService.GetDetailAsync(id, _currentUserId);
            _isRegistered = _selected.IsRegistered;
            oldextra = _selected.Extra;
        }
        catch (Exception ex)
        {
            Toast.ShowError("Fehler beim Auswählen", ex.Message);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task Register()
    {
        if (_selected is null) return;

        _busy = true;
        try
        {
            var (ok, error) = await ActivityService.RegisterAsync(_selected.Id, _currentUserId);
            if (!ok) { Toast.ShowWarning("Achtung", error ?? "Nicht möglich."); return; }

            Toast.ShowSuccess("Erfolg", "Du bist angemeldet.");
            await Select(_selected.Id);
            _activities = await ActivityService.GetListAsync(_currentUserId);
        }
        finally
        {
            _busy = false;
        }
    }
    private async Task RegisterAdmin()
    {
        if (_selected is null) return;
        
        _busy = true;
        try
        {
            var (ok, error) = await ActivityService.RegisterAsync(_selected.Id, _selectedUserId??0,true);
            if (!ok) { Toast.ShowWarning("Achtung", error ?? "Nicht möglich."); return; }
            await ActivityService.UpdateExtraAsync(adminExtra,_selected.Id,_selectedUserId??0);

            Toast.ShowSuccess("Erfolg", $"Du hast die Person erfolgreich angemeldet.");
            await Select(_selected.Id);
            _activities = await ActivityService.GetListAsync(_currentUserId);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task Unregister()
    {
        if (_selected is null) return;

        _busy = true;
        try
        {
            var (ok, error) = await ActivityService.UnregisterAsync(_selected.Id, _currentUserId);
            if (!ok) { Toast.ShowWarning("Achtung", error ?? "Nicht möglich.", 10000); return; }

            Toast.ShowInfo("Abmeldung", "Du bist abgemeldet.");
            await Select(_selected.Id);
            _activities = await ActivityService.GetListAsync(_currentUserId);
        }
        finally
        {
            _busy = false;
        }
    }
    private async Task UnregisterAdmin(int userId)
    {
        if (_selected is null) return;

        _busy = true;
        try
        {
            var (ok, error) = await ActivityService.UnregisterAsync(_selected.Id, userId,true);
            if (!ok) { Toast.ShowWarning("Achtung", error ?? "Nicht möglich.", 10000); return; }

            Toast.ShowInfo("Abmeldung", "Du hast die Person erfolgreich abgemeldet.");
            await Select(_selected.Id);
            _activities = await ActivityService.GetListAsync(_currentUserId);
        }
        finally
        {
            _busy = false;
        }
    }
    private async Task UpdateExtra(){
        if (_selected is null) return;
        _busy =true;
        try{

            var max =Math.Max(_selected.MaxTeilnehmer-_selected.ActiveCount+oldextra,oldextra);
            var maxUsed =max<_selected.Extra&&_selected.MaxTeilnehmer>0;
            if(maxUsed)_selected.Extra=max<0?0:max;
            _selected.Extra=_selected.Extra<0?0:_selected.Extra;
            var (ok,error) = await ActivityService.UpdateExtraAsync(_selected.Extra,_selected.Id,_currentUserId);
            if(!ok||maxUsed){
                Toasts.ShowWarning( "Achtung",error??$"Du hast erfolgreich +{_selected.Extra} angemeldet");
            }else{
            Toast.ShowSuccess("Anmeldung",$"Du hast erfolgreich +{_selected.Extra} angemeldet");
            }
            await Select(_selected.Id);
            _activities = await ActivityService.GetListAsync(_currentUserId);
            oldextra=_selected.Extra;
        }finally{
            _busy=false;
        }
    } 
    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;

        // Limits
        var allowed = new[] { "image/jpeg", "image/png", "image/webp" };
        if (!allowed.Contains(_selectedFile.ContentType))
        {
            Toast.ShowWarning("Falsche Format","Bitte JPG/PNG/WebP hochladen.");
            ClearSelection();
            return;
        }

        const long maxBytes = 2 * 1024 * 1024; // 2 MB
        if (_selectedFile.Size > maxBytes)
        {
            Toast.ShowWarning("Achtung","Bild ist zu groß (max 2MB).");
            ClearSelection();
            return;
        }

        // Vorschau als DataURL
        using var stream = _selectedFile.OpenReadStream(maxBytes);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        _new.Data = ms.ToArray();
        _new.FileName = _selectedFile.Name;
        _new.ContentType = _selectedFile.ContentType;

        _previewDataUrl = ToDataUrl(_new.ContentType, _new.Data);
    }
     private void ClearSelection()
    {
        _selectedFile = null;
        _previewDataUrl = null;
    }
    private void OpenModal()
    {
        _showModal = true;
    }
    private void CloseModal()
    {
        _showModal = false;
    }
    private static string ToDataUrl(string contentType, byte[] data)
        => $"data:{contentType};base64,{Convert.ToBase64String(data)}";
        
    private void ResetNew(){
        var date = _new.Datum;
        _new = new ActivityCreateVm();
        _new.Datum = date;
        _selectedFile = null;
        _previewDataUrl = "";
        _new.UnregisteredAt = DateTime.Today;
        _selectedLoaded =false;
        _editGroupIds.Clear();
    }
    private async Task Create()
    {
        // Minimal-Validierung
        if (string.IsNullOrWhiteSpace(_new.Name) || string.IsNullOrWhiteSpace(_new.Ort))
        {
            Toast.ShowWarning("Achtung", "Name und Ort sind Pflicht.");
            return;
        }
        if (_new.MaxTeilnehmer < 0&&_new.EmpfohleneTeilnehmer<0)
        {
            Toast.ShowWarning("Achtung", "Beide Teilnehmer dürfen nicht negativ sein.");
            return;
        }

        _busy = true;
        try
        {
            var date = _new.Datum;

            var id = await ActivityService.CreateAsync(_new);
            var (ok,error) = await ActivityService.SetActivityGroupsAsync(id,_editGroupIds);
            if(!ok)Toast.ShowError("Erstellen nicht möglich",error??"Unbekannter Fehler");
            else{
            Toast.ShowSuccess("Erfolg", "Aktivität erstellt.");
            ResetNew();
            await Select(id);}
        }
        catch (Exception ex)
        {
            Toast.ShowError("Fehler bei der Erstellung", ex.Message);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task Save(){
         // Minimal-Validierung
        if (string.IsNullOrWhiteSpace(_new.Name) || string.IsNullOrWhiteSpace(_new.Ort))
        {
            Toast.ShowWarning("Achtung", "Name und Ort sind Pflicht.");
            return;
        }
        if (_new.MaxTeilnehmer < 0&&_new.EmpfohleneTeilnehmer<0)
        {
            Toast.ShowWarning("Achtung", "Beide Teilnehmer dürfen nicht negativ sein.");
            return;
        }

        _busy = true;
        try
        {   
            var (ok,error) = await ActivityService.UpdateActivityAsync(_new,_selectedId);
            if (!ok) { Toast.ShowWarning("Fehler beim speichern", error ?? "Nicht möglich.", 10000); return; }
            (ok,error) = await ActivityService.SetActivityGroupsAsync(_selectedId, _editGroupIds.Any()?_editGroupIds:_new.GroupIds);
            Toast.ShowSuccess("Erfolg", "Aktivität gespeichert.");
            ResetNew();
            _activities = await ActivityService.GetListAsync(_currentUserId);
            await Select(_selectedId);
        }
        catch (Exception ex)
        {
            Toast.ShowError("Fehler bei der Erstellung", ex.Message);
        }
        finally
        {
            _busy = false;
        }
    }
    private void LoadSelectedIntoEditor()
    {
        if (_selected is null) return;
        _selectedId = _selected.Id;
        _selectedLoaded=true;
        _selectedFile = null;
        _previewDataUrl="";
        _new = new ActivityCreateVm
        {
            Name = _selected.Name,
            Ort = _selected.Ort,
            Info = _selected.Info,
            MaxTeilnehmer = _selected.MaxTeilnehmer,
            Datum = _selected.Datum,
            UnregisteredAt=_selected.LastUnregistrationAt??DateTime.UtcNow,
            EmpfohleneTeilnehmer = _selected.EmpfohleneTeilnehmer,
            Data= _selected.Data,
            FileName= _selected.FileName,
            ContentType= _selected.ContentType,
            GroupIds = _selected.GroupIds
        };
        if (!string.IsNullOrWhiteSpace(_selected.ContentType))
        _previewDataUrl = ToDataUrl(_selected.ContentType, _selected.Data);
        Toast.ShowInfo("Daten geladen!", "Daten in den Editor geladen (Erstellen speichert die Eingabe als neue Aktivität).");
    }
