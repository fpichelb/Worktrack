@page "/training-plan"
@using System.Globalization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Http.HttpResults
@using Worktrack.ViewModels
@attribute [Authorize]

@inject TrainingPlannerService TrainingPlannerService

<PageTitle>Trainingsplan</PageTitle>

<h3 class="card">Trainingsplan</h3>

@if (_loading)
{
    <div class="d-flex align-items-center gap-2">
        <div class="spinner-border" role="status" aria-hidden="true"></div>
        <span class="text-muted">Lade Trainingsplan...</span>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="row g-3">
        <div class="col-12">
            <div class="card">
                <div class="card-body d-flex flex-wrap align-items-center justify-content-between gap-2">
                    <div>
                        <div class="small text-muted">Woche</div>
                        <div class="fs-5 fw-semibold">
                            @_week.WeekStart.ToString("dd.MM.yyyy") - @_week.WeekStart.AddDays(6).ToString("dd.MM.yyyy")
                        </div>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <button class="btn btn-outline-secondary" @onclick="PreviousWeek">Vorherige Woche</button>
                        <button class="btn btn-outline-secondary" @onclick="CurrentWeek">Heute</button>
                        <button class="btn btn-primary" @onclick="NextWeek">Nächste Woche</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 @(_selected is null ?"":"col-xxl-8")">
            @if (_week.Rooms.Count == 0)
            {
                <div class="alert alert-info mb-0">
                    Noch keine Trainingsräume vorhanden. Admins können unten Räume anlegen.
                </div>
            }
            else
            {
                <div class="training-room-tabs">
                    <button class="training-room-tab @(SelectedRoomId == AllRoomsId ? "is-active" : "")"
                            style="background:@(SelectedRoomId == AllRoomsId ? "#0f172a" : "#e2e8f0")"
                            @onclick="() => SelectRoom(AllRoomsId)">
                        Alle Räume
                    </button>
                    @foreach (var room in _week.Rooms)
                    {
                        var active = room.Id == SelectedRoomId;
                        <button class="training-room-tab @(active ? "is-active" : "")"
                                style="background:@(active ? room.Color : "#e2e8f0")"
                                @onclick="() => SelectRoom(room.Id)">
                            @room.Name
                        </button>
                    }
                </div>

                <div class="training-calendar-shell">
                    <div class="training-calendar-header">
                        <div class="training-calendar-time-header small text-muted">Zeit</div>
                        @foreach (var day in _week.Days)
                        {
                            <div class="training-calendar-day">
                                <div class="fw-semibold">@day.ToString("dddd")</div>
                                <div class="small text-muted">@day.ToString("dd.MM.")</div>
                            </div>
                        }
                    </div>

                    <div class="training-calendar-body" style="@GetCalendarBodyStyle()">
                        <div class="training-time-axis">
                            @foreach (var marker in TimeMarkers)
                            {
                                <div class="training-time-marker" style="@GetMarkerStyle(marker)">
                                    <span>@marker.ToString("HH:mm")</span>
                                </div>
                            }
                        </div>

                        @foreach (var day in _week.Days)
                        {
                            var dayEvents = GetSelectedRoomDayEvents(day).ToList();
                            <div class="training-day-lane">
                                @foreach (var marker in TimeMarkers.Skip(1))
                                {
                                    <div class="training-day-line" style="@GetMarkerStyle(marker)"></div>
                                }

                                @if (dayEvents.Count == 0)
                                {
                                    <div class="training-empty p-2">Kein Termin</div>
                                }
                                else
                                {
                                    @foreach (var item in dayEvents)
                                    {
                                        var selected = _selected?.OccurrenceKey == item.OccurrenceKey;
                                        var tooltip = GetEventTooltip(item);
                                        <button class="training-event-card @(selected ? "is-selected" : "")"
                                                style="@GetEventStyle(item)"
                                                title="@tooltip"
                                                @onclick="() => SelectEvent(item.OccurrenceKey)">
                                            @if (SelectedRoomId == AllRoomsId)
                                            {
                                                <span class="visually-hidden">@tooltip</span>
                                            }
                                            else
                                            {
                                                <div class="fw-semibold">@item.Title</div>
                                                <div class="small text-muted">
                                                    @item.StartAt.ToString("HH:mm") - @item.EndAt.ToString("HH:mm")
                                                </div>
                                                <div class="small mt-1">
                                                    @if (item.MaxParticipants > 0)
                                                    {
                                                        <span>@item.ParticipantCount / @item.MaxParticipants Teiln.</span>
                                                    }
                                                    else
                                                    {
                                                        <span>@item.ParticipantCount Teiln.</span>
                                                    }
                                                </div>
                                                @if (item.IsRecurring)
                                                {
                                                    <div class="small text-muted mt-1">Serie</div>
                                                }
                                            }
                                        </button>
                                    }
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="col-12 @(_selected is null ?"":"col-xxl-4")">
            @if (_selected is null)
            {
                <div class="alert alert-info mb-0">Wähle einen Termin aus dem Wochenraster aus.</div>
            }
            else
            {
                <div class="card">
                    <div class="card-body pt-0">
                        <div class="d-flex justify-content-between align-items-start gap-2 ">
                            <div>
                                <h4 class="mb-1">@_selected.Title</h4>
                                <div class="text-muted">@_selected.RoomName</div>
                            </div>
                            <div>
                            <span class="training-meta-chip">@_selected.StartAt.ToString("dd.MM. HH:mm")</span>
                            <button class="btn-remove ms-3 p-auto position-absolute" @onclick="()=>_selected = null">✕</button>
                            </div>
                        </div>

                        <div class="mt-3">
                            <div class="small text-muted">Zeit</div>
                            <div>@_selected.StartAt.ToString("dddd, dd.MM.yyyy HH:mm") - @_selected.EndAt.ToString("HH:mm")</div>
                        </div>

                        <div class="mt-3">
                            <div class="small text-muted">Beschreibung</div>
                            <div>@(string.IsNullOrWhiteSpace(_selected.Description) ? "Keine Zusatzinfos." : _selected.Description)</div>
                        </div>

                        <div class="mt-3 d-flex flex-wrap gap-2">
                            <span class="training-meta-chip">@_selected.ParticipantCount Teilnehmer</span>
                            @if (_selected.MaxParticipants > 0)
                            {
                                <span class="training-meta-chip">max. @_selected.MaxParticipants</span>
                            }
                            @if (_selected.RecommendedParticipants > 0)
                            {
                                <span class="training-meta-chip">empf. @_selected.RecommendedParticipants</span>
                            }
                            @if (_selected.IsRecurring)
                            {
                                <span class="training-meta-chip">wiederkehrend</span>
                            }
                        </div>

                        <div class="mt-3 d-flex flex-wrap gap-2">
                            <span class="badge text-bg-light">Mitglieder: @(_selected.AllowMemberRegistration ? "offen" : "gesperrt")</span>
                            <span class="badge text-bg-light">Gruppen später: @(_selected.AllowGroupRegistration ? "vorbereitet" : "nein")</span>
                            <span class="badge text-bg-light">Eventeintrag später: @(_selected.AllowParticipantEventSubmission ? "vorbereitet" : "nein")</span>
                        </div>

                        <div class="mt-4 d-flex flex-wrap gap-2">
                            @if (_selected.AllowMemberRegistration)
                            {
                                @if (_selected.IsCurrentUserRegistered)
                                {
                                    <button class="btn btn-remove" disabled="@_busy" @onclick="UnregisterMe">Abmelden</button>
                                }
                                else
                                {
                                    <button class="btn btn-primary" disabled="@_busy" @onclick="RegisterMe">Anmelden</button>
                                }
                            }
                        </div>

                        @if (_selected.IsRecurring)
                        {
                            <div class="small text-muted mt-2">
                                Serie: @_selected.RecurrencePattern
                                @if (_selected.RecurrenceUntil.HasValue)
                                {
                                    <span> bis @_selected.RecurrenceUntil.Value.ToString("dd.MM.yyyy")</span>
                                }
                            </div>
                        }

                        <AuthorizeView Roles="admin,actManager">
                            <div class="mt-3 d-flex flex-wrap gap-2">
                                <button class="btn btn-outline-danger" disabled="@_busy" @onclick="CancelSelectedOccurrence">
                                    Diesen Termin entfernen
                                </button>
                                @if (_selected.SeriesId.HasValue)
                                {
                                    <button class="btn btn-outline-warning" disabled="@_busy" @onclick="StopSelectedSeries">
                                        Serie ab hier beenden
                                    </button>
                                }
                            </div>
                        </AuthorizeView>

                        <hr />

                        <h5 class="mb-2">Teilnehmerliste</h5>
                        @if (_selected.Participants.Count == 0)
                        {
                            <div class="text-muted">Noch niemand eingetragen.</div>
                        }
                        else
                        {
                            <div class="list-group">
                                @foreach (var participant in _selected.Participants)
                                {
                                    <div class="list-group-item d-flex justify-content-between align-items-start gap-2">
                                        <div>
                                            <div class="fw-semibold">
                                                @participant.DisplayName
                                                @if (participant.ParticipantCount > 1)
                                                {
                                                    <span class="text-muted">x @participant.ParticipantCount</span>
                                                }
                                            </div>
                                            <div class="small text-muted">
                                                @participant.ParticipantType
                                                @if (!string.IsNullOrWhiteSpace(participant.SourceGroupName))
                                                {
                                                    <span>- Gruppe: @participant.SourceGroupName</span>
                                                }
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(participant.Notes))
                                            {
                                                <div class="small">@participant.Notes</div>
                                            }
                                        </div>
                                        <div class="text-end">
                                            <div class="small text-muted">@participant.RegisteredAt.ToLocalTime().ToString("dd.MM. HH:mm")</div>
                                            <AuthorizeView Roles="admin,actManager">
                                                <button class="btn btn-sm btn-outline-danger mt-2" @onclick="() => RemoveParticipant(participant.Id)">Entfernen</button>
                                            </AuthorizeView>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        
