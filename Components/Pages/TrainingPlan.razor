@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private bool _loading = true;
    private bool _busy;
    private bool _showRooms=false;
    private string? _error;
    private int _currentUserId;
    private TrainingWeekVm _week = new();
    private TrainingEventDetailVm? _selected;
    private DateTime _currentWeekStart = StartOfWeek(DateTime.Today);
    private TrainingEventEditVm _editor = new();
    private int? _editingEventId;
    private int? _editingSeriesId;
    private DateTime? _editingOccurrenceDate;
    private bool _editSeriesFromOccurrence;
    private string _newRoomName = "";
    private string _newRoomColor = "#2563eb";
    private string _userQuery = "";
    private List<User> _userHits = new();
    private CancellationTokenSource? _searchCts;
    private TrainingParticipantEditVm _participantEditor = new();
    private const int AllRoomsId = 0;
    private int? _selectedRoomId;
    private const int HourHeightPx = 88;

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUserAsync();
        _editor.Date = DateTime.Today;
        await LoadWeekAsync();
    }

    private async Task LoadCurrentUserAsync()
    {
        if (AuthenticationStateTask is null)
            return;

        var auth = await AuthenticationStateTask;
        var userIdStr = auth.User.FindFirst("UserId")?.Value;
        _currentUserId = int.TryParse(userIdStr, out var parsed) ? parsed : 0;
    }

    private async Task LoadWeekAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _week = await TrainingPlannerService.GetWeekAsync(_currentWeekStart, _currentUserId);
            EnsureSelectedRoom();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private int SelectedRoomId => _selectedRoomId ?? AllRoomsId;

    private TimeOnly CalendarStart
    {
        get
        {
            var weekEvents = _week.Events.ToList();
            if (weekEvents.Count == 0)
                return new TimeOnly(17, 0);

            var minStart = weekEvents.Min(x => TimeOnly.FromDateTime(x.StartAt));
            return new TimeOnly(minStart.Hour, 0);
        }
    }

    private TimeOnly CalendarEnd
    {
        get
        {
            var weekEvents = _week.Events.ToList();
            if (weekEvents.Count == 0)
                return new TimeOnly(21, 0);

            var maxEnd = weekEvents.Max(x => TimeOnly.FromDateTime(x.EndAt));
            var roundedEnd = new TimeOnly(maxEnd.Hour, 0);
            if (maxEnd.Minute > 0 || maxEnd.Second > 0)
                roundedEnd = roundedEnd.AddHours(1);
            return roundedEnd;
        }
    }

    private double CalendarHeightPx
    {
        get
        {
            var minutes = Math.Max(240, (CalendarEnd.ToTimeSpan() - CalendarStart.ToTimeSpan()).TotalMinutes);
            return minutes / 60d * HourHeightPx;
        }
    }

    private IEnumerable<TimeOnly> TimeMarkers
    {
        get
        {
            for (var current = CalendarStart; current <= CalendarEnd; current = current.AddHours(1))
                yield return current;
        }
    }

    private IEnumerable<TrainingWeekEventVm> SelectedRoomEvents =>
        _week.Events
            .Where(x => SelectedRoomId == AllRoomsId || x.TrainingRoomId == SelectedRoomId)
            .OrderBy(x => x.StartAt);

    private bool IsEditing => _editingEventId.HasValue || _editingSeriesId.HasValue;

    private IEnumerable<TrainingWeekEventVm> GetSelectedRoomDayEvents(DateTime day)
    {
        return SelectedRoomEvents
            .Where(x => x.StartAt.Date == day.Date)
            .OrderBy(x => x.StartAt);
    }

    private void SelectRoom(int roomId)
    {
        _selectedRoomId = roomId;
    }

    private void EnsureSelectedRoom()
    {
        if (!_selectedRoomId.HasValue)
        {
            _selectedRoomId = AllRoomsId;
            return;
        }

        if (_selectedRoomId != AllRoomsId && !_week.Rooms.Any(x => x.Id == _selectedRoomId.Value))
            _selectedRoomId = AllRoomsId;
    }

    private double GetMarkerTopPx(TimeOnly marker)
    {
        return (marker.ToTimeSpan() - CalendarStart.ToTimeSpan()).TotalMinutes / 60d * HourHeightPx;
    }

    private string GetCalendarBodyStyle()
    {
        return string.Create(CultureInfo.InvariantCulture, $"--lane-height:{CalendarHeightPx:F1}px");
    }

    private string GetMarkerStyle(TimeOnly marker)
    {
        var top = GetMarkerTopPx(marker);
        return string.Create(CultureInfo.InvariantCulture, $"top:{top:F1}px");
    }

    private string GetEventStyle(TrainingWeekEventVm item)
    {
        var startTime = TimeOnly.FromDateTime(item.StartAt);
        var endTime = TimeOnly.FromDateTime(item.EndAt);
        var top = (startTime.ToTimeSpan() - CalendarStart.ToTimeSpan()).TotalMinutes / 60d * HourHeightPx;
        var height = Math.Max(44, (endTime.ToTimeSpan() - startTime.ToTimeSpan()).TotalMinutes / 60d * HourHeightPx);

        if (SelectedRoomId == AllRoomsId)
        {
            var roomCount = Math.Max(1, _week.Rooms.Count);
            var roomIndex = _week.Rooms.FindIndex(x => x.Id == item.TrainingRoomId);
            if (roomIndex < 0)
                roomIndex = 0;

            var widthPercent = 100d / roomCount;
            var leftPercent = widthPercent * roomIndex;

            return string.Create(
                CultureInfo.InvariantCulture,
                $"--room-color:{item.RoomColor};top:{top:F1}px;height:{height:F1}px;left:calc({leftPercent:F4}% + 0.3rem);width:calc({widthPercent:F4}% - 0.6rem);right:auto;");
        }

        return string.Create(
            CultureInfo.InvariantCulture,
            $"--room-color:{item.RoomColor};top:{top:F1}px;height:{height:F1}px;");
    }

    private string GetEventTooltip(TrainingWeekEventVm item)
    {
        var recurring = item.IsRecurring ? " | Serie" : "";
        return $"{item.RoomName}: {item.Title} ({item.StartAt:HH:mm} - {item.EndAt:HH:mm}){recurring}";
    }

