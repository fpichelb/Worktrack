    private void LoadSelectedIntoEditor()
    {
        if (_selected is null)
            return;

        _editingEventId = _selected.IsRecurring ? null : _selected.EventId;
        _editingSeriesId = _selected.SeriesId;
        _editingOccurrenceDate = _selected.StartAt;
        _editSeriesFromOccurrence = false;
        _editor = new TrainingEventEditVm
        {
            Title = _selected.Title,
            Description = _selected.Description,
            TrainingRoomId = _selected.TrainingRoomId,
            Date = _selected.StartAt.Date,
            StartTime = TimeOnly.FromDateTime(_selected.StartAt),
            EndTime = TimeOnly.FromDateTime(_selected.EndAt),
            MaxParticipants = _selected.MaxParticipants,
            RecommendedParticipants = _selected.RecommendedParticipants,
            AllowMemberRegistration = _selected.AllowMemberRegistration,
            AllowGroupRegistration = _selected.AllowGroupRegistration,
            AllowParticipantEventSubmission = _selected.AllowParticipantEventSubmission,
            IsRecurring = _selected.IsRecurring,
            RecurrencePattern = _selected.IsRecurring ? _selected.RecurrencePattern : "weekly",
            RecurrenceInterval = 1,
            RecurrenceUntil = _selected.RecurrenceUntil
        };

        var message = _selected.IsRecurring ? "Serie in den Editor geladen." : "Ausgewählten Termin in den Editor geladen.";
        Toasts.ShowInfo("Editor", message);
    }

    private void LoadSelectedSeriesFromHereIntoEditor()
    {
        if (_selected?.SeriesId is null)
            return;

        LoadSelectedIntoEditor();
        _editSeriesFromOccurrence = true;
        _editingSeriesId = _selected.SeriesId.Value;
        _editingOccurrenceDate = _selected.StartAt;
        _editor.IsRecurring = true;
        _editor.Date = _selected.StartAt.Date;

        Toasts.ShowInfo("Editor", "Serie ab diesem Termin zur Bearbeitung geladen.");
    }

    private async Task UpdateEvent()
    {
        if (!IsEditing)
            return;

        _busy = true;
        try
        {
            bool ok;
            string? error;
            string? occurrenceKey;

            if (_editingEventId.HasValue)
            {
                (ok, error) = await TrainingPlannerService.UpdateEventAsync(_editingEventId.Value, _editor);
                occurrenceKey = $"single:{_editingEventId.Value}";
            }
            else if (_editingSeriesId.HasValue && _editSeriesFromOccurrence && _editingOccurrenceDate.HasValue)
            {
                (ok, error, occurrenceKey) = await TrainingPlannerService.SplitSeriesFromOccurrenceAsync(_editingSeriesId.Value, _editingOccurrenceDate.Value, _editor);
            }
            else if (_editingSeriesId.HasValue)
            {
                (ok, error, _) = await TrainingPlannerService.UpdateSeriesAsync(_editingSeriesId.Value, _editor);
                occurrenceKey = _selected?.OccurrenceKey;
            }
            else
            {
                return;
            }

            if (!ok)
            {
                Toasts.ShowWarning("Achtung", error ?? "Nicht möglich.");
                return;
            }

            var message = _editingSeriesId.HasValue
                ? (_editSeriesFromOccurrence ? "Serie ab hier aktualisiert." : "Serie aktualisiert.")
                : "Termin aktualisiert.";

            Toasts.ShowSuccess("Erfolg", message);
            ResetEditor();

            if (!string.IsNullOrWhiteSpace(occurrenceKey))
                await ReloadSelectionAndWeekAsync(occurrenceKey);
            else
                await LoadWeekAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task OnUserQueryChanged(ChangeEventArgs e)
    {
        _userQuery = e.Value?.ToString() ?? "";
        _userHits.Clear();
        _participantEditor.UserId = null;

        if (_userQuery.Trim().Length < 2)
            return;

        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        var ct = _searchCts.Token;

        try
        {
            await Task.Delay(250, ct);
            _userHits = await UService.GetBestUsers(_userQuery.Trim(), 10, ct);
        }
        catch (OperationCanceledException)
        {
        }
    }

