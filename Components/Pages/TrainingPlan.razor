                                    <div class="col-12">
                                        <label class="form-label">Beschreibung</label>
                                        <textarea class="form-control" rows="3" @bind="_editor.Description"></textarea>
                                    </div>

                                    @* <div class="col-md-3">
                                        <label class="form-label">Max. Teilnehmer</label>
                                        <input class="form-control" type="number" min="0" @bind="_editor.MaxParticipants" />
                                    </div>

