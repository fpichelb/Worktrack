@page "/teamstats"
@attribute [Authorize]
@using Worktrack.ViewModels
@inject NavigationManager Nav
@inject UserService UService
@inject TeamStatsService TeamStatsService

<h2>Team Event Statistik</h2>
<AuthorizeView Context="auth">
    <Authorized>
        @if (!_loaded)
        {
            <p>Lade Daten...</p>
        }
        else
        {
            <div class="card">
                <h3>Team Performance (Gesamtjahr)</h3>
                <p class="text-gray">Stunden & Eventteilnahmen für alle Mitglieder, die sich vergleichen wollen.</p>
                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>Events besucht</th>
                                <th>Gesamtstunden</th>
                                <th>Achievements</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in _stats.GlobalStats)
                            {
                                <tr>
                                    <td>@u.Rank</td>
                                    <td>@u.Name</td>
                                    <td>@u.EventsVisited</td>
                                    <td>@u.TotalHours.ToString("0.0") h</td>
                                    <td>
                                        @foreach (var a in u.Achievements)
                                        {
                                            <span class="badge @a.ColorCss" data-bs-toggle="tooltip" title="@a.Tooltip">@a.Shown</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <details class="achievement-legend-panel">
                    <summary>Achievement-Legende anzeigen</summary>
                    <div class="achievement-legend">
                        @foreach (var item in TeamAchievementLegend)
                        {
                            <div class="achievement-legend__item">
                                <span class="badge text-bg-secondary achievement-legend__badge">@item.Icon</span>
                                <span>@item.Label</span>
                            </div>
                        }
                    </div>
                </details>
            </div>

            @foreach (var group in _stats.SeasonGroups)
            {
                <div class="card">
                    <h3>@group.Season.Name</h3>

                    @if (!group.Events.Any())
                    {
                        <p>Keine Events in dieser Saison</p>
                    }
                    else
                    {
                        @foreach (var ev in group.Events)
                        {
                            <div style="margin-top:1.5rem;">
                                <h4>@ev.Name (@ev.Location)</h4>
                                <p class="text-gray">@ev.StartTime.ToShortDateString()</p>
                                @if (!group.Podium.Any())
                                {
                                    <p>Keine Teilnehmer.</p>
                                }
                            </div>
                        }

                        @if (group.Podium.Any())
                        {
                            <div style="display:flex; gap:1rem; margin:1rem 0;">
                                @if (group.Podium.Count >= 2)
                                {
                                    <div class="podium-card">
                                        <div class="podium-rank silver">2</div>
                                        <div class="podium-name">@group.Podium[1].Name</div>
                                        <div class="podium-hours">@group.Podium[1].Hours.ToString("0.0") h</div>
                                    </div>
                                }

                                <div class="podium-card">
                                    <div class="podium-rank gold">1</div>
                                    <div class="podium-name">@group.Podium[0].Name</div>
                                    <div class="podium-hours">@group.Podium[0].Hours.ToString("0.0") h</div>
                                </div>

                                @if (group.Podium.Count >= 3)
                                {
                                    <div class="podium-card">
                                        <div class="podium-rank bronze">3</div>
                                        <div class="podium-name">@group.Podium[2].Name</div>
                                        <div class="podium-hours">@group.Podium[2].Hours.ToString("0.0") h</div>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            }
        }
    </Authorized>
</AuthorizeView>

@code {
    [CascadingParameter]
    Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private bool _loaded;
    private TeamStatsVm _stats = new();
    private static readonly (string Icon, string Label)[] TeamAchievementLegend =
    [
        ("👋", "Newcomer: mindestens ein Event besucht."),
        ("🏃", "Eventrunner: mindestens drei verschiedene Events besucht."),
        ("🎉⚔️", "Eventveteran: mindestens zehn verschiedene Events besucht."),
        ("🔥", "20+ Stunden: mindestens 20 Stunden im aktuellen Vergleich."),
        ("🌟", "50+ Stunden: mindestens 50 Stunden im aktuellen Vergleich."),
        ("💯", "100+ Stunden: mindestens 100 Stunden im aktuellen Vergleich."),
        ("🌸🍂🚀❄️☀️", "Season Hero: Teilnahme über alle berücksichtigten Saisonbereiche hinweg."),
        ("🥈🏆🥉", "Permanentes Podium: irgendwann beim Archivieren Top 3 mit mindestens 15 Stunden erreicht.")
    ];

    protected override async Task OnParametersSetAsync()
    {
        if (_loaded)
            return;

        if (AuthenticationStateTask is null)
            return;

        var auth = await AuthenticationStateTask;
        if (auth.User.Identity?.IsAuthenticated != true)
            return;

        var userId = auth.User.FindFirst("UserId")?.Value;
        if (userId is null)
            return;

        var currentUser = await UService.GetUserByStringId(userId);
        if (currentUser is null)
            return;

        if (!currentUser.ShareStats)
        {
            Nav.NavigateTo("/user/dashboard");
            return;
        }

        _stats = await TeamStatsService.GetTeamStatsAsync();
        _loaded = true;
    }
}
