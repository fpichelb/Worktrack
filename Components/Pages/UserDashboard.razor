@page "/user/dashboard"
@attribute [Authorize]
@using Microsoft.VisualBasic

@inject NavigationManager Nav
@inject AppDbContext Db
@inject AuthStateProvider Auth
@rendermode InteractiveServer

<h2>User Dashboard</h2>

@if ((CurrentUser is null))
{
    <p>Lade Daten...</p>
}
else
{
    <div class="container">

        <!-- HEADER -->
        <div class="card">
            <h2>Hallo, @CurrentUser.Name!</h2>
            <p>Hier findest du alle deine Arbeitsstunden und Teilnahmen.</p>
        </div>

        <!-- USER HOURS SUMMARY -->
        <div class="card">
            <h3>Deine Statistik</h3>
            <div class="table-responsive">
                <table class="info-table">
                    <tr>
                        <td><strong>Bonusstunden:</strong></td>
                        <td>@CurrentUser.BonusHours.ToString("0") h</td>
                    </tr>
                    <tr>
                        <td><strong>Gesamtstunden:</strong></td>
                        <td>@TotalHours.ToString("0.0") h</td>
                    </tr>
                    <tr>
                        <td><strong>Besuchte Einsätze/Events:</strong></td>
                        <td>@EventsVisited</td>
                    </tr>
                </table>
            </div>
        </div>

        <!-- TEAM COMPARISON OPT-IN -->
        <div class="card">
            <h3>Teamvergleich</h3>

            <p>Wenn du zustimmst, erscheinst du im Teamranking und kannst deine Leistungen mit anderen vergleichen.</p>
            <label for="sharestats" style="display:flex;  justify-content: center; margin-right:1rem;">Ich möchte am
                Teamvergleich teilnehmen</label>
            <label style="display:flex; align-items:center; gap:0.5rem;">

                <input type="checkbox" id="sharestats" checked="@CurrentUser.ShareStats" @onchange="(e => saveStats(e))" />
            </label>

            <div style="margin-top:1rem;justify-content: center;display:flex;">
                @if (CurrentUser.ShareStats == true)
                {
                    <a class="btn btn-primary" href="/teamstats?code=@CurrentUser.SecretCode">
                        ➜ Zum Teamvergleich
                    </a>
                }
                else
                {
                    <button class="btn btn-secondary" disabled>
                        Teamvergleich deaktiviert
                    </button>
                }
            </div>
        </div>

        <!-- MY EVENTS -->
        <div class="card">
            <h3>Meine Events</h3>

            @if (!MyEventStats.Any())
            {
                <p>Du hast bisher an keinen Events teilgenommen.</p>
            }
            else
            {

                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr>
                                <th>Event</th>
                                <th>Ort</th>
                                <th>Datum</th>
                                <th>Beschreibung</th>
                                <th>Stunden</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ev in MyEventStats)
                            {
                                <tr>
                                    <td>@ev.EventName</td>
                                    <td>@ev.Location</td>
                                    <td>@ev.Date.ToShortDateString()</td>
                                    <td>@ev.Hours.ToString("0.0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- LOGOUT / BACK -->
        <div class="card" style="text-align:center;">
            <button class="btn btn-secondary" @onclick="Logout">
                Logout
            </button>
        </div>

    </div>
}

@code {
    private User? CurrentUser;
    private List<TimeEntry> UserEntries = new();
    private List<EventStatsModel> MyEventStats = new();

    private double TotalHours = 0;
    private int EventsVisited = 0;

    private bool _loaded = false;

   protected override async Task OnAfterRenderAsync(bool firstRender)
{
    if (_loaded)
        return;
    await Task.Delay(500);
    var authed = await Auth.GetCurrentUserAsync();
    if (authed == null)
        return; // WARTEN, nicht redirecten

    _loaded = true;
    CurrentUser = authed;
    await LoadStats();
    StateHasChanged();
}

    private async Task saveStats(ChangeEventArgs e)
    {
        if (CurrentUser is null) return;
        CurrentUser.ShareStats = bool.TryParse(e.Value?.ToString(), out var v) && v;
        Db.Users.Update(CurrentUser);
        await Db.SaveChangesAsync();
        StateHasChanged();

    }

    private async Task LoadStats()
    {
        UserEntries = await Db.TimeEntry
        .Where(e => e.UserId == CurrentUser!.Id && e.CheckOut != null && e.IsArchived == false)
        .Include(e => e.Event)
        .ToListAsync();

        TotalHours = UserEntries.Sum(e =>
        e.DurationHours ?? 0);

        if (!(CurrentUser is null))
            TotalHours += CurrentUser.BonusHours;

        EventsVisited = UserEntries
        .Select(e => e.EventId)
        .Distinct()
        .Count();

        MyEventStats = UserEntries
        .GroupBy(e => e.EventId)
        .Select(g => new EventStatsModel
        {
            EventId = g.Key,
            EventName = g.First().Event!.Name,
            Location = g.First().Event!.Location,
            Date = g.First().CheckIn ?? DateTime.MinValue,
            Hours = g.Sum(e =>
    (e.DurationHours ?? 0))
        })
        .OrderByDescending(x => x.Date)
        .ToList();
    }


    private void Logout()
    {
        Nav.NavigateTo("/auth/logout", forceLoad: true);
    }

    public class EventStatsModel
    {
        public int EventId { get; set; }
        public string EventName { get; set; } = "";
        public string Location { get; set; } = "";
        public DateTime Date { get; set; }
        public double Hours { get; set; }
    }
}