@page "/user/dashboard"
@attribute [Authorize]
@using Microsoft.VisualBasic
@inject NavigationManager Nav
@inject NewsService NService
@inject UserService UService
@inject UserStatsService UserStatsService
@inject ToastService Toasts

<h2>User Dashboard</h2>

<AuthorizeView Context="auth">
    <Authorized>
@if (!_loaded)
{
    <p>Lade Daten!...</p>
}
else
{
    <div class="container">

        <!-- HEADER -->
        <div class="card">
            <div class="row g-2">
            <div class="col-md-6">
            <h2>Hallo, @CurrentUser?.Name!</h2>
            <p>Hier findest du alle deine Arbeitsstunden und Teilnahmen.</p>
            </div>
            <div class="col-md-6">
            <h2>News</h2>
            <div class="row g-2">
            @foreach (var n in _news)
                {
                    <div class="card col-md-4 p-0">
                    <a  href="@($"/news/view/{n.Id}")" target="_blank"class="btn p-0 border-0 bg-transparent ">
                        @if (n.ContentType.StartsWith("image/"))
                        {
                            <div class="position-relative  hover-parent">
                                <img class="card-img-top" src="@($"/news/file/{n.Id}")" style="height:90px; object-fit:cover; cursor:zoom-in;" />
                            <div class="position-absolute top-0 end-100  ms-2 d-none hover-child border-5" style="z-index:9100;">
                                <img src="@($"/news/file/{n.Id}")"
                                  class="rounded shadow"
                                  style="width:240px; " />
                            </div>
                            </div>
                        }
                        else
                        {
                            <div class="p-4 text-center text-muted"style="height:90px; object-fit:cover;">
                                <div class="fw-semibold">PDF</div>
                            </div>
                        }

                        
                        <h6 class="card-title text-center "style="color:black;" title="@n.Title">@n.Title</h6>
                        
                    </a>
                    </div>
                }
                </div>
            </div>
            </div>
        </div>

        <!-- USER HOURS SUMMARY -->
        <div class="card">
            <h3>Deine Statistik</h3>
            <div class="table-responsive">
                <table class="info-table">
                    <tr>
                        <td><strong>Bonusstunden:</strong></td>
                        <td>@CurrentUser?.BonusHours.ToString("0") h</td>
                    </tr>
                    <tr>
                        <td><strong>Gesamtstunden:</strong></td>
                        <td>@TotalHours.ToString("0.0") h</td>
                    </tr>
                    <tr>
                        <td><strong>Archivierte Stunden:</strong></td>
                        <td>@CurrentUser?.ArchivedHours.ToString("0.0") h</td>
                    </tr>
                    <tr>
                        <td><strong>Besuchte Einsätze/Events:</strong></td>
                        <td>@EventsVisited</td>
                    </tr>
                </table>
            </div>
        </div>

        <!-- TEAM COMPARISON OPT-IN -->
        <div class="card">
            <h3>Teamvergleich</h3>

            <p>Wenn du zustimmst, erscheinst du im Teamranking und kannst deine Leistungen mit anderen vergleichen.</p>
            <label for="sharestats" class="d-flex align-items-center"style="justify-content: center; ">Ich möchte am
                Teamvergleich teilnehmen</label>
            <label class="d-flex align-items-center gap-1" >

                <input type="checkbox" id="sharestats" checked="@CurrentUser?.ShareStats" @onchange="(e => saveStats(e))" />
            </label>

            <div style="margin-top:1rem;justify-content: center;display:flex;">
                @if (CurrentUser?.ShareStats == true)
                {
                    <a class="btn btn-primary" href="/teamstats">
                        ➜ Zum Teamvergleich
                    </a>
                }
                else
                {
                    <button class="btn btn-secondary" disabled>
                        Teamvergleich deaktiviert
                    </button>
                }
            </div>
        </div>

        <div class="card">
            <h3>Login-Code</h3>
            <p>Wenn du möchtest, kannst du dir einen neuen Secret Code erzeugen. Der bisherige Code wird dadurch sofort ungültig.</p>
            <div class="d-flex flex-wrap align-items-center gap-2">
                <button class="btn btn-outline-warning" disabled="@_regeneratingCode" @onclick="RegenerateSecretCode">
                    @(_regeneratingCode ? "Wird neu erzeugt..." : "Secret Code neu generieren")
                </button>
                @if (!string.IsNullOrWhiteSpace(_newSecretCodeInfo))
                {
                    <span class="text-muted">@_newSecretCodeInfo</span>
                }
            </div>
        </div>

        @if (ArchivedAchievements.Any())
        {
            <div class="card">
                <h3>Erreichte Achievements</h3>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var achievement in ArchivedAchievements)
                    {
                        var title = achievement.IsPermanent
                            ? $"{achievement.Label} (permanent)"
                            : achievement.ArchiveYear.HasValue
                                ? $"{achievement.Label} {achievement.ArchiveYear.Value}"
                                : achievement.Label;

                        <span class="achievement-chip" title="@title">
                            <span class="badge achievement-chip__badge achievement-chip__badge--gold">
                                @GetAchievementBadge(achievement)
                            </span>
                            @if (achievement.ArchiveYear.HasValue)
                            {
                                <span class="badge achievement-chip__year achievement-chip__year--gold">@achievement.ArchiveYear.Value</span>
                            }
                        </span>
                    }
                </div>
                <details class="achievement-legend-panel">
                    <summary>Achievement-Legende anzeigen</summary>
                    <div class="achievement-legend">
                        @foreach (var item in DashboardAchievementLegend)
                        {
                            <div class="achievement-legend__item">
                                <span class="badge achievement-legend__badge achievement-chip__badge--gold">@item.Icon</span>
                                <span>@item.Label</span>
                            </div>
                        }
                    </div>
                </details>
            </div>
        }

        <!-- MY EVENTS -->
        <div class="card">
            <h3>Meine Events</h3>

            @if (!MyEventStats.Any())
            {
                <p>Du hast bisher an keinen Events teilgenommen.</p>
            }
            else
            {

                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr>
                                <th>Event</th>
                                <th>Ort</th>
                                <th>Datum</th>
                                <th>Beschreibung</th>
                                <th>Stunden</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ev in MyEventStats)
                            {
                                <tr>
                                    <td>@ev.EventName</td>
                                    <td>@ev.Location</td>
                                    <td>@ev.Date.ToShortDateString()</td>
                                    <td>@ev.Description</td>
                                    <td>@ev.Hours.ToString("0.0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- LOGOUT / BACK -->
        <div class="card" style="text-align:center;">
            <button class="btn btn-secondary" @onclick="Logout">
                Logout
            </button>
        </div>

    </div>

      
}
 </Authorized>
</AuthorizeView>


@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }
    private User? CurrentUser;
    private List<UserDashboardEventVm> MyEventStats = new();
    private bool _loaded;
    private List<NewsItem> _news =new List<NewsItem>();
    private double TotalHours = 0;
    private int EventsVisited = 0;
    private List<UserArchivedAchievementVm> ArchivedAchievements = new();
    private string UserLoginUrl="/user/login";
    private bool _regeneratingCode;
    private string _newSecretCodeInfo = "";
    private static readonly (string Icon, string Label)[] DashboardAchievementLegend =
    [
        ("👋", "Newcomer: Du hast im archivierten Zeitraum mindestens ein Event besucht."),
        ("🏃", "Eventrunner: Du hast im archivierten Zeitraum mindestens drei verschiedene Events besucht."),
        ("🎉⚔️", "Eventveteran: Du hast im archivierten Zeitraum mindestens zehn verschiedene Events besucht."),
        ("🔥", "20+ Stunden: Du hast im archivierten Zeitraum mindestens 20 Stunden gesammelt."),
        ("🌟", "50+ Stunden: Du hast im archivierten Zeitraum mindestens 50 Stunden gesammelt."),
        ("💯", "100+ Stunden: Du hast im archivierten Zeitraum mindestens 100 Stunden gesammelt."),
        ("🥈🏆🥉", "Podium: Du warst beim Archivieren unter den Top 3 und hattest dabei mindestens 15 Stunden."),
        ("🌸🍂🚀❄️☀️", "Season Hero: Dieses Symbol steht für eine vollständige Teilnahme über alle Saisons bzw. Saisonbereiche hinweg.")
    ];
    

    protected override async Task OnParametersSetAsync()
    {
    if (_loaded)
    return;

    if (AuthenticationStateTask is null){
        return;
    }   
    var auth = await AuthenticationStateTask;
    if (auth.User.Identity?.IsAuthenticated != true){
        Nav.NavigateTo(UserLoginUrl);
        return;
    }
    var userId = auth.User.FindFirst("UserId")?.Value;
    if (userId is null){
        Nav.NavigateTo(UserLoginUrl);
        return;
        }

    if (!int.TryParse(userId, out var parsedUserId))
        return;

    await LoadDashboardAsync(parsedUserId);
    if (CurrentUser is null)
        return;

    _loaded = true;
    _news=await NService.ListPinnedForDashboardAsync();
    
   
}

    private async Task saveStats(ChangeEventArgs e)
    {
        if (CurrentUser is null) return;
        CurrentUser.ShareStats = bool.TryParse(e.Value?.ToString(), out var v) && v;
        await UService.UpdateUser(CurrentUser);
        StateHasChanged();

    }

    private async Task LoadDashboardAsync(int userId)
    {
        var dashboard = await UserStatsService.GetDashboardAsync(userId);
        if (dashboard is null)
            return;

        CurrentUser = dashboard.User;
        TotalHours = dashboard.TotalHours;
        EventsVisited = dashboard.EventsVisited;
        ArchivedAchievements = dashboard.ArchivedAchievements;
        MyEventStats = dashboard.Events;
    }

    private async Task RegenerateSecretCode()
    {
        if (CurrentUser is null || _regeneratingCode)
            return;

        _regeneratingCode = true;
        _newSecretCodeInfo = "";

        try
        {
            var (ok, error, newCode) = await UService.RegenerateSecretCodeAsync(CurrentUser.Id);
            if (!ok)
            {
                Toasts.ShowError("Fehler", error ?? "Secret Code konnte nicht neu erzeugt werden.");
                return;
            }

            CurrentUser.SecretCode = newCode ?? CurrentUser.SecretCode;
            _newSecretCodeInfo = $"Neuer Code: {CurrentUser.SecretCode}";
            Toasts.ShowSuccess("Secret Code aktualisiert", "Dein bisheriger Code ist nicht mehr gültig.");
        }
        finally
        {
            _regeneratingCode = false;
        }
    }


    private void Logout()
    {
        Nav.NavigateTo("/auth/logout", forceLoad: true);
    }

    private static string GetAchievementBadge(UserArchivedAchievementVm achievement)
    {
        return achievement.Kind switch
        {
            "newcomer" => "👋",
            "eventrunner" => "🏃",
            "eventveteran" => "🎉⚔️",
            "hardworker" => "🔥",
            "fiftyhours" => "🌟",
            "hundredhours" => "💯",
            "podium-year" => "🥈🏆🥉",
            "podium-permanent" => "🥈🏆🥉",
            "seasonhero" => "🌸🍂🚀❄️☀️",
            _ => string.IsNullOrWhiteSpace(achievement.BadgeText) ? "🏅" : achievement.BadgeText
        };
    }

}
