@page "/admin/users"
@layout AdminLayout
@rendermode InteractiveServer


@using System.Text
@inject AppDbContext Db
@inject IJSRuntime JS
@inject UserService UService

@inject ToastService Toasts



<h2>Benutzerverwaltung</h2>

<div class="card">
    <div style="display:flex; justify-content:space-between; align-items:center;">
        <div>
            <h3>Benutzer</h3>
            <p class="text-gray">Alle registrierten Nutzer</p>
        </div>
        <div>
            <a class="btn secondary" style="margin-right:0.5rem;" href="/admin/import-users">User Import</a>
            <button class="btn" style="margin-right:0.5rem;" @onclick="ShowDetails">Show Details</button>
            <button class="btn" style="margin-right:0.5rem;" @onclick="ShowAddUser">Show AddUser</button>
            <button class="btn" @onclick="ExportCsv">CSV Export</button>

        </div>
    </div>

    <div style="margin-top:1rem; display:flex; gap:0.5rem;">
    
        <input placeholder="Suche nach Name oder E-Mail" @bind="@SearchTerm" @onkeydown="LoadUsers" />
        <button class="btn secondary" @onclick="LoadUsers">Suchen</button>

    </div>

    @if (showAddUser)
    {

        <div class="card" style="margin-bottom:2rem;">

            <h3>Neuen Nutzer hinzufügen</h3>

            <div class="form-group">

                <label>Name</label>
                <input class="form-control" @bind="Name" />

            </div>

            <div class="form-group">

                <label>Email (optional)</label>
                <input class="form-control" @bind="Email" />

            </div>

            <div class="form-group">

                <label>Admin?</label>
                <input type="checkbox" @bind="newUserIsAdmin" />

            </div>

            <button class="btn btn-primary" @onclick="AddUser">Hinzufügen</button>

        </div>

    }

    @if (IsLoading)
    {
        <p style="margin-top:1rem;">Lade Benutzer</p>
    }
    else if (!Users.Any())
    {
        <p style="margin-top:1rem;">Keine Benutzer gefunden.</p>
    }
    else
    {
        <div class="table-responsive">
            <table style="margin-top:1rem;">
                <thead>
                    <tr>
                        @if (showDetails){
                        <th>Name<br>Rolle</th>

                        
                        
                            <th>E-Mail<br /> Secret Code</th>
                        }else{
                            <th>Name</th>
                            <th>Secret Code</th>
                        }

                        @if (showDetails)
                        {
                            <th class="text-right">Archiv-Stunden</th>
                        }

                        <th class="text-right">Aktuelle Stunden</th>
                        <!--- <th class="text-right">Gesamt</th>--->
                        <th class="text-left">Bonus</th>
                        @if (showDetails)
                        {
                            <th class="text-right">Aktionen</th>
                        }

                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Users)
                    {
                        var current = GetCurrentHours(u.Id);
                        //var total = u.ArchivedHours + current;
                        <tr>
                            <td style="width: 180px;">
                                @if (showDetails)
                                {
                                    <InputText style="width: 180px;" @bind-Value="u.Name" @bind-Value:after="() => Save(u)" />
                                    <select class="form-select form-select-sm" value="@u.Role"
                                        @onchange="(e) => ChangeRole(u,e.Value?.ToString())">
                                        <option value="user">User</option>
                                        <option value="actManager">ActManager</option>
                                        <option value="admin">Admin</option>
                                        <option value="admin">Trainer</option>
                                        <option value="admin">Betreuer</option>
                                    </select>
                                }
                                else
                                {
                                    @u.Name
                                }
                            </td>
                            @if (showDetails)
                            {
                                <td>@u.Email<br />
                                <InputText  style="width: 80px;" @bind-Value="u.SecretCode" @bind-Value:after="() => Save(u)" /></td>
                            }else{
                            <td>
                                @u.SecretCode
                            </td>
                            }
                            @if (showDetails)
                            {
                                <td class="text-right">@u.ArchivedHours.ToString("0.0")</td>
                            }
                            <td class="text-right">@current.ToString("0.0")</td>
                            <td>
                                <InputNumber @bind-Value="u.BonusHours" @bind-Value:after="() => Save(u)" />
                            </td>
                            <!--- <td class="text-right">@total.ToString("0.0")</td>-->
                            @if (showDetails)
                            {
                                <td class="text-right">
                                    <button class="btn btn-danger" @onclick="() => DeleteUser(u)">Löschen</button>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private bool PreventEnter(KeyboardEventArgs e) => e.Key == "Enter";
    private List<User> Users = new();
    private readonly Dictionary<User, System.Timers.Timer> _debounceTimers = new();
    private List<TimeEntry> Entries = new();
    private string SearchTerm = "";
    private bool IsLoading = true;
    private bool showDetails = false;
    private bool showAddUser = false;
    private string Name = "";
    private string Email = "";
    private bool newUserIsAdmin = false;


    [Inject] public NavigationManager Nav { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }
    private async Task AddUser()
    {
        try
        {
            var user = await UService.AddSingleUserAsync(Name, Email, newUserIsAdmin);
            Console.WriteLine($"PAGE SERVICE INSTANCE: {Toasts.GetHashCode()}");
            Toasts.ShowSuccess("Benutzer angelegt", $"{user.Name} wurde hinzugefügt. Geheimcode: {user.SecretCode}");
            // Felder leeren
            Name = "";
            Email = "";
            newUserIsAdmin = false;
        }
        catch (Exception ex)
        {
            Toasts.ShowError("Fehler beim Anlegen", $"{ex.Message}");
        }
    }

    private async Task LoadUsers()
    {
        IsLoading = true;

        var query = Db.Users.AsQueryable();

        if (!string.IsNullOrWhiteSpace(SearchTerm))
        {
            query = query.Where(u =>
            u.Name.Contains(SearchTerm) || (u.Email != null && u.Email.Contains(SearchTerm)));
        }

        Users = await query.OrderBy(u => u.Name).ToListAsync();

        Entries = await Db.TimeEntry
        .Where(e => e.CheckIn != null && e.CheckOut != null && !e.IsArchived)
        .ToListAsync();
       
        IsLoading = false;
        StateHasChanged();
    }


    private double GetCurrentHours(int userId)
    {
        return Entries
        .Where(e => e.UserId == userId && e.CheckIn != null && e.CheckOut != null)
        .Sum(e => (e.DurationHours ?? 0));
    }


    private async Task Save(User u)
    {
        await Db.SaveChangesAsync();
        await LoadUsers();
    }


    private async Task ChangeRole(User u, string? newRole){
        if (newRole is null) return;
        u.Role = newRole;
        await Db.SaveChangesAsync();
        Toasts.ShowInfo("Rolle aktualisiert", $" {u.Name} ist jetzt {newRole}.");
        await LoadUsers();
    }

    private async Task DeleteUser(User u)
    {
        Db.Users.Remove(u);
        await Db.SaveChangesAsync(); 
        Toasts.ShowInfo("Benutzer gelöscht", $"{u.Name} wurde entfernt.");
        await LoadUsers();
    }

    private void ShowDetails()
    {
        if (showDetails) showDetails = false;
        else showDetails = true;
    }

    private void ShowAddUser()
    {
        if (showAddUser) showAddUser = false;
        else showAddUser = true;
    }


    private async Task ExportCsv()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Name,Email,SecretCode,Role,ShareStats,ArchivedHours,CurrentHours,TotalHours");

        foreach (var u in Users)
        {
            var current = GetCurrentHours(u.Id);
            var total = u.ArchivedHours + current;

            sb.AppendLine($"{Escape(u.Name)},{Escape(u.Email)},{Escape(u.SecretCode)},{u.Role},{u.ShareStats},{u.ArchivedHours:0.0},{current:0.0},{total:0.0}");
        }

        var bytes = Encoding.UTF8.GetBytes(sb.ToString());
        var base64 = Convert.ToBase64String(bytes);
        var url = $"data:text/csv;base64,{base64}";
        var fileName = $"worktrack-users-{DateTime.Now:yyyyMMdd}.csv";

        await JS.InvokeVoidAsync("downloadFile", url, fileName);
    }

    private string Escape(string? value)
    => "\"" + (value ?? "").Replace("\"", "\"\"") + "\"";

}