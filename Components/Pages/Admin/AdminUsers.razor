@page "/admin/users"
@layout AdminLayout
@rendermode InteractiveServer


@using System.Text
@inject AppDbContext Db
@inject IJSRuntime JS

<h2>Benutzerverwaltung</h2>

<div class="card">
    <div style="display:flex; justify-content:space-between; align-items:center;">
        <div>
            <h3>Benutzer</h3>
            <p class="text-gray">Alle registrierten Nutzer</p>
        </div>
        <div>
            <a class="btn secondary" style="margin-right:0.5rem;" href="/admin/import-users">User Import</a>
            <button class="btn" style="margin-right:0.5rem;" @onclick="ShowAktionen">Show Aktionen</button>
            <button class="btn" @onclick="ExportCsv">CSV Export</button>
        </div>
    </div>

    <div style="margin-top:1rem; display:flex; gap:0.5rem;">
        <input placeholder="Suche nach Name oder E-Mail…" @bind="@SearchTerm" />
        <button class="btn secondary" @onclick="LoadUsers">Suchen</button>
    </div>

    @if (IsLoading)
    {
        <p style="margin-top:1rem;">Lade Benutzer…</p>
    }
    else if (!Users.Any())
    {
        <p style="margin-top:1rem;">Keine Benutzer gefunden.</p>
    }
    else
    {
        <table style="margin-top:1rem;">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>E-Mail</th>
                    <th>Secret Code</th>
                    <th>Rolle</th>
                    <th class="text-right">Archiv-Stunden</th>
                    <th class="text-right">Aktuelle Stunden</th>
                   <!--- <th class="text-right">Gesamt</th>--->
                    @if(showActions){
                    <th class="text-right">Aktionen</th>}
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Users)
                {
                    var current = GetCurrentHours(u.Id);
                    //var total = u.ArchivedHours + current;

                    <tr>
                        <td>@u.Name</td>
                        <td>@u.Email</td>
                        <td>@u.SecretCode</td>
                        <td>@(u.Role == "admin" ? "Admin" : "User")</td>
                        <td class="text-right">@u.ArchivedHours.ToString("0.0")</td>
                        <td class="text-right">@current.ToString("0.0")</td>
                       <!--- <td class="text-right">@total.ToString("0.0")</td>-->
                        @if(showActions){
                        <td class="text-right">
                            @if (u.Role != "admin")
                            {
                                <button class="btn secondary" style="margin-right:0.5rem;margin-bottom:0.5rem;" @onclick="() => MakeAdmin(u)">Admin</button>
                            }
                            <button class="btn secondary" @onclick="() => DeleteUser(u)">Löschen</button>
                        </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<User> Users = new();
    private List<TimeEntry> Entries = new();
    private string SearchTerm = "";
    private bool IsLoading = true;
    private bool showActions = false;

    [Inject] public NavigationManager Nav { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        IsLoading = true;

        var query = Db.Users.AsQueryable();
        if (!string.IsNullOrWhiteSpace(SearchTerm))
        {
            query = query.Where(u =>
                u.Name.Contains(SearchTerm) || (u.Email != null && u.Email.Contains(SearchTerm)));
        }

        Users = await query.OrderBy(u => u.Name).ToListAsync();

        Entries = await Db.TimeEntry
            .Where(e => e.CheckIn != null && e.CheckOut != null && !e.IsArchived)
            .ToListAsync();

        IsLoading = false;
    }

    private double GetCurrentHours(int userId)
    {
        return Entries
            .Where(e => e.UserId == userId && e.CheckIn != null && e.CheckOut != null)
            .Sum(e => (e.CheckOut!.Value - e.CheckIn!.Value).TotalHours);
    }

    

    private async Task MakeAdmin(User u)
    {
        u.Role = "admin";
        await Db.SaveChangesAsync();
        await LoadUsers();
    }

    private async Task DeleteUser(User u)
    {
        Db.Users.Remove(u);
        await Db.SaveChangesAsync();
        await LoadUsers();
    }

    private void ShowAktionen(){
        if(showActions)showActions=false;
        else showActions=true;
    }
    private async Task ExportCsv()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Name,Email,SecretCode,Role,ShareStats,ArchivedHours,CurrentHours,TotalHours");

        foreach (var u in Users)
        {
            var current = GetCurrentHours(u.Id);
            var total = u.ArchivedHours + current;

            sb.AppendLine($"{Escape(u.Name)},{Escape(u.Email)},{Escape(u.SecretCode)},{u.Role},{u.ShareStats},{u.ArchivedHours:0.0},{current:0.0},{total:0.0}");
        }

        var bytes = Encoding.UTF8.GetBytes(sb.ToString());
        var base64 = Convert.ToBase64String(bytes);
        var url = $"data:text/csv;base64,{base64}";
        var fileName = $"worktrack-users-{DateTime.Now:yyyyMMdd}.csv";

        await JS.InvokeVoidAsync("downloadFile", url, fileName);
    }

    private string Escape(string? value)
        => "\"" + (value ?? "").Replace("\"", "\"\"") + "\"";
}