@page "/admin/pending"
@layout AdminLayout


@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@rendermode InteractiveServer


<h2>Offene Zeiteinträge</h2>

<div class="card">
    <h3>Zuordnung ausstehend</h3>

    @if (Pending == null)
    {
        <p>Lade…</p>
    }
    else if (!Pending.Any())
    {
        <p>Keine offenen Einträge.</p>
    }
    else
    {<div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>Name eingegeben</th>
                    <th>Event</th>
                    <th>Task</th>
                    <th>Check-In</th>
                    <th>Check-Out</th>
                    <th>Nutzer zuordnen</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Pending)
                {
                    <tr>
                        <td>@e.NameEntered</td>
                        <td>@e.Event?.Name</td>
                        <td>@(string.IsNullOrEmpty(e.Task) ? "-" : e.Task)</td>
                        <td>@e.CheckIn.Value.ToLocalTime()</td>
                        <td>@(e.CheckOut.HasValue? e.CheckOut.Value.ToLocalTime().ToString() : "-")</td>
                        <td>
                            <select  @onchange="(args) => AssignUser(e, args.Value?.ToString())">
                                <option value="">-- User wählen --</option>

                                @{
                                    var sortedUsers = GetSortedUsersForEntry(e);
                                }
                                @foreach (var u in sortedUsers)
                                {
                                    <option value="@u.Id">@u.Name</option>
                                }
                            </select>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
</div>

@code {
    private List<TimeEntry>? Pending;
    private List<User> Users = new();

    protected override async Task OnInitializedAsync()
    {
        Pending = await Db.TimeEntry
        .Include(t => t.Event)
        .Where(t => t.Status == "pending_assignment")
        .OrderByDescending(t => t.CheckIn)
        .ToListAsync();

        Users = await Db.Users.ToListAsync();
    }

    private List<User> GetSortedUsersForEntry(TimeEntry entry)
    {
        return Users
        .OrderByDescending(u => GetMatchScore(entry.NameEntered, u.Name))
        .ToList();
    }

    private async Task AssignUser(TimeEntry entry, string? value)
    {
        if (int.TryParse(value, out var userId))
        {
            var user = Users.FirstOrDefault(u => u.Id == userId);
            if (user == null) return;

            entry.UserId = userId;
            entry.UserName= user.Name;
            entry.Status = entry.CheckOut.HasValue ? "checked_out" : "checked_in";

            await Db.SaveChangesAsync();

            Pending?.Remove(entry);
            StateHasChanged();
        }
    }

    private int Levenshtein(string a, string b)
    {
        if (string.IsNullOrEmpty(a)) return b.Length;
        if (string.IsNullOrEmpty(b)) return a.Length;

        int[,] d = new int[a.Length + 1, b.Length + 1];

        for (int i = 0; i <= a.Length; i++) d[i, 0] = i;
        for (int j = 0; j <= b.Length; j++) d[0, j] = j;

        for (int i = 1; i <= a.Length; i++)
        {
            for (int j = 1; j <= b.Length; j++)
            {
                int cost = (a[i - 1] == b[j - 1]) ? 0 : 1;

                d[i, j] = Math.Min(
                Math.Min(d[i - 1, j] + 1, d[i, j - 1] + 1),
                d[i - 1, j - 1] + cost
                );
            }
        }

        return d[a.Length, b.Length];
    }

    private double GetMatchScore(string entered, string fullName)
    {
        entered = entered.ToLower();
        fullName = fullName.ToLower();

        double score = 0;

        // 1. String-Distance
        var dist = Levenshtein(entered, fullName);
        score -= dist; // niedrig besser → negativ nutzen

        // 2. Teilstring-Bonus
        if (fullName.Contains(entered)) score += 10;

        // 3. Token-Vergleich
        var tokens = fullName.Split(' ');
        var enteredTokens = entered.Split(' ');

        foreach (var t in enteredTokens)
        {
            foreach (var ft in tokens)
            {
                if (ft.StartsWith(t)) score += 5;
                if (ft == t) score += 10;
            }
        }

        return score;
    }

}