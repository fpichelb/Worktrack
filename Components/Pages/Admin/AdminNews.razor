@page "/admin/news"
@layout AdminLayout
@inject NewsService NService

<h2>Newsverwaltung</h2>
<div class="card">
    <div class="card-header">News Upload (PDF/Bild)</div>
        <div class="card-body">
            <div class="mb-2">
                    <label class="form-label">Titel</label>
                    <input class="form-control" @bind="NewsTitle" />
                </div>

                <div class="row g-2">
                    <div class="col-md-6">
                        <div>
                        <label class="form-label">Von</label>
                        <input class="form-control" type="datetime-local" @bind="PublishFromLocal" />
                        </div>
                        <div class="form-check mt-2">
                         
                    <input type="checkbox" class="form-check-input" id="pin" @bind="_usePublishTo"/>
                    <label class="form-check-label" for="pin"> Automatisch Verstecken?</label>
                    </div>
                    @if(_usePublishTo){
                    <div >
                        <label class="form-label">Bis (optional)</label>
                        <input class="form-control" type="datetime-local" @bind="PublishToLocal" />
                    </div>
                    }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(PreviewDataUrl))
                {
                    <div class="col-md-6 text-center mt-auto">
                        <div class="text-muted small">Vorschau</div>
                        <img src="@PreviewDataUrl" class="img-thumbnail" style="max-height:160px;" />
                        </div>
                }
                </div>

                <div class="form-check mt-2">
                    <input class="form-check-input " type="checkbox" id="pin" @bind="IsPinned">
                    <label class="form-check-label ml-2" for="pin"> Anheften</label>
                </div>

                <div class="mt-3">
                    <InputFile OnChange="OnNewsFileSelected" accept="application/pdf,image/*" />
                </div>

                <button class="btn btn-success mt-3" disabled="@Busy" @onclick="UploadNews">
                    Upload
                </button>
            </div>
        </div>

        <hr />

        <h5>Bestehende News</h5>
        @if (NewsItems.Count == 0)
        {
            <div class="text-muted">Noch keine News.</div>
        }
        else
        {
            <div class="list-group">
                @foreach (var n in NewsItems)
                {
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <div class="me-3">
                            <div class="fw-semibold">@n.Title @if(n.IsPinned){<span class="badge text-bg-warning ms-1">PIN</span>}</div>
                            <div class="small text-muted">
                                @n.PublishFrom.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                @if (n.PublishTo is not null)
                                {
                                    <span>– @n.PublishTo.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                                }
                                <span class="ms-2">@n.ContentType</span>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <a class="btn btn-outline-secondary btn-sm" href="@($"/news/file/{n.Id}")" target="_blank">Öffnen</a>
                            <button class="btn btn-outline-danger btn-sm" disabled="@Busy" @onclick="() => DeleteNews(n.Id)">Löschen</button>
                        </div>
                    </div>
                }
            </div>
        }
    

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private string Tab = "features";
    private bool Busy;

    private List<NewsItem> NewsItems = new();

    private string NewsTitle = "";
    private bool IsPinned;

    // datetime-local bindet am besten string
    private DateTime PublishFromLocal = DateTime.Now;
    private DateTime PublishToLocal = DateTime.Now;

    private IBrowserFile? SelectedFile;
    private string? PreviewDataUrl;
    bool _usePublishTo =true;

    protected override async Task OnInitializedAsync()
    {
        Busy=false;
        NewsItems = await NService.ListForAdminAsync();
    }

    private async Task OnNewsFileSelected(InputFileChangeEventArgs e)
    {
        SelectedFile = e.File;
        PreviewDataUrl = null;

        // Preview nur für Bilder (PDF: kein Preview)
        if (SelectedFile.ContentType.StartsWith("image/"))
        {
            const long maxBytes = 2 * 1024 * 1024;
            await using var s = SelectedFile.OpenReadStream(maxBytes);
            using var ms = new MemoryStream();
            await s.CopyToAsync(ms);
            var bytes = ms.ToArray();
            PreviewDataUrl = $"data:{SelectedFile.ContentType};base64,{Convert.ToBase64String(bytes)}";
        }
    }

    private async Task UploadNews()
    {
        if (SelectedFile is null) return;

        Busy = true;
        try
        {
            var from = PublishFromLocal;
            DateTime? to = _usePublishTo ? PublishToLocal:null;

            var userId = 1; // TODOOO

            await NService.CreateAsync(
                NewsTitle,
                from,
                to,
                IsPinned,
                SelectedFile,
                userId);

            Toasts.ShowSuccess("Erfolg","News hochgeladen.");

            // Reset
            NewsTitle = "";
            IsPinned = false;
            SelectedFile = null;
            PreviewDataUrl = null;

            NewsItems = await NService.ListForAdminAsync();
        }
        catch (Exception ex) { Toasts.ShowError("Fehler",ex.Message); }
        finally { Busy = false; }
    }

    private async Task DeleteNews(int id)
    {
        Busy = true;
        try
        {
            await NService.DeleteAsync(id);
            Toasts.ShowSuccess("Erfolg","News gelöscht.");
            NewsItems = await NService.ListForAdminAsync();
        }
        catch (Exception ex) { Toasts.ShowError("Fehler",ex.Message); }
        finally { Busy = false; }
    }
}