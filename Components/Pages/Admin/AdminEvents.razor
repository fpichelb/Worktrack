@page "/admin/events"
@layout AdminLayout

@using Microsoft.EntityFrameworkCore
@inject EventService EService
@inject TimeEntryService TEService
@inject NavigationManager Nav
@rendermode InteractiveServer


<h2>Event-Verwaltung</h2>

<div class="card">
    <h3>Neues Event anlegen</h3>

    <EditForm Model="@NewEvent" OnValidSubmit="@CreateEvent" FormName="CreateEvent">
        <DataAnnotationsValidator />


        <label>Name</label>
        <input @bind="@NewEvent.Name" />

        <label>Ort</label>
        <input @bind="@NewEvent.Location" />

        <div class="event-grid">
            <div>
                <label>Datum</label>
                <input type="date" class="form-control" @bind="@NewEvent.StartTime" />
            </div>
            <div class="checkbox-group" style="margin-top:0.75rem;">
                <label for="am" style="margin-bottom:1.3rem;">Auto-Match Benutzer</label>
                <input type="checkbox" id="am" @bind="@NewEvent.AutoMatchUsers" />
            </div>
            <div class="checkbox-group" style="margin-top:0.5rem;">
                <label for="rt" style="margin-bottom:1.3rem;">Aufgabe erforderlich</label>
                <input type="checkbox" id="rt" @bind="@NewEvent.RequireTask" />
            </div>
        </div>

        <label>Beschreibung</label>
        <input @bind="@NewEvent.Description" />

        <label>Standardstunden (Auto-Checkout)</label>
        <input @bind="@NewEvent.DefaultHours" />





        <button type="submit" class="btn mt-4">Event speichern</button>
    </EditForm>
</div>

<div class="card">
    <h3>Bestehende Events</h3>

    @if (Events == null)
    {
        <p>Lade Events…</p>
    }
    else if (Events.Count == 0)
    {
        <p>Keine Events vorhanden.</p>
    }
    else
    {

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Ort</th>
                        <th>EventQR-Code</th>
                        <th>AutoMatch</th>
                        <th>Aktiv</th>
                        <th class="text-right">Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Events)
                    {
                        <tr>
                            <td>
                                <InputText @bind-value="e.Name" @bind-value:after="() => Save(e)" />
                            </td>
                            <td>@e.Location</td>
                            <td>
                                @if (QrCache.ContainsKey(e.Id))
                                {
                                    <img src="@QrCache[e.Id]" style="width:80px; border:1px solid #ccc; padding:3px;" />
                                }

                                <br />
                                <button class="btn btn-secondary btn-small" @onclick="() => ShowLargeQR(e.Id)">
                                    QR groß
                                </button>
                            </td>
                            <td>
                                <InputCheckbox @bind-Value="e.AutoMatchUsers" @bind-Value:after="() => Save(e)" />
                            </td>
                            <td>@(e.IsActive ? "Ja" : "Nein")</td>
                            <td class="text-right">
                                <button class="btn secondary" style="margin:0.5rem;" @onclick="() => ToggleActive(e)">
                                    @(e.IsActive ? "Deaktivieren" : "Aktivieren")
                                </button>
                                <button class="btn secondary" style="margin:0.5rem;" @onclick="() => DeleteEvent(e)">Löschen</button>
                                <button class="btn secondary" style="margin:0.5rem;" @onclick="() => SelectEvent(e)">Details</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
@if (SelectedEvent != null)
{
    <h3 class="mt-4">Timeentries für @SelectedEvent.Name</h3>

    @if (!EventEntries.Any())
    {
        <p>Keine Einträge vorhanden.</p>
    }
    else
    {

        <div class="table-responsive">
            <table class="stats-table">
                <thead>
                    <tr>
                        <th>Zugewiesen</th>
                        <th>Eingegeben</th>
                        <th>Check-In</th>
                        <th>Check-Out</th>
                        <th>Dauer (h)</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in EventEntries)
                    {
                        <tr>
                            <td>@(e.UserName ?? "")</td>
                            <td>@(e.NameEntered)</td>
                            <td>@e.CheckIn?.ToString("g")</td>
                            <td>@e.CheckOut?.ToString("g")</td>
                            <td>@((e.DurationHours ?? 0).ToString("0.0"))</td>
                            <td>@e.Status</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

<!-- GROßES QR POPUP -->
@if (LargeQrBase64 != null)
{
    <div class="qr-backdrop" @onclick="CloseLargeQR">
        <div class="qr-popup" @onclick:stopPropagation>
            <h3>QR-Code Event</h3>
            <img src="@LargeQrBase64" style="width:300px; border:2px solid #333; padding:10px;" />

            <br />
            <a href="@LargeQrBase64" download="Event-QR.png" class="btn btn-primary" style="margin-top:1rem;">
                Herunterladen
            </a>

            <button class="btn btn-secondary" style="margin-top:1rem;" @onclick="CloseLargeQR">
                Schließen
            </button>
        </div>
    </div>
}

@code {
    private List<Event>? Events;
    private Event NewEvent = new();
    private Dictionary<int, string> QrCache = new();
    private string? LargeQrBase64 = null;
    private Event? SelectedEvent = null;
    private List<TimeEntry> EventEntries = new();

    protected override async Task OnInitializedAsync()
    {
        NewEvent.StartTime = DateTime.Today;
        Events = await EService.GetAllEventsAsync();

        foreach (var e in Events)
        {
            var url = $"{Nav.BaseUri.TrimEnd('/')}/event?event={e.Id}";
            QrCache[e.Id] = await QrHelper.GeneratePngBase64(url);
        }
    }
    private async Task Save(Event e)
    {
        await EService.UpdateEventAsync(e);
    }

    private async Task SelectEvent(Event e)
    {   
        SelectedEvent=e;
        EventEntries = await TEService.GetEntriesForEventAsync(e.Id);
        StateHasChanged();
    }

    private async Task CreateEvent()
    {
        if (string.IsNullOrWhiteSpace(NewEvent.Name) || string.IsNullOrWhiteSpace(NewEvent.Location))
            return;


        NewEvent.IsActive = true;

        await EService.CreateEventAsync(NewEvent);
        StateHasChanged();
        NewEvent = new();
    }

    private async Task ToggleActive(Event e)
    {
        e.IsActive = !e.IsActive;
        await EService.UpdateEventAsync(e);
    }

    private async Task DeleteEvent(Event e)
    {

        await EService.DeleteEventAsync(e.Id);
        Events?.Remove(e);

    }

    private void ShowLargeQR(int eventId)
    {
        LargeQrBase64 = QrCache[eventId];
        StateHasChanged();
    }

    private void CloseLargeQR()
    {
        LargeQrBase64 = null;
    }
}