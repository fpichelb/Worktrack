@page "/admin/archive"
@using Microsoft.EntityFrameworkCore
@layout AdminLayout
@rendermode InteractiveServer

@inject UserService Uservice
@inject TimeEntryService TEservice


<h2>Stunden archivieren</h2>

<div class="card">
    <div class="Event-grid">
        <div>
        <p>Hier kannst du die seit dem letzten Archiv gesammelten Stunden der Nutzer endgültig verbuchen.</p>
        </div>
        <div>
        </div>
        <div>
        @if (!Confirm)
        {
            <button class="btn btn-danger" @onclick="() => Confirm = true">Alle Nutzer archivieren</button>
        }
        else
        {
            <div>
                <strong>Bist du sicher?</strong><br />
                <button class="btn btn-success" @onclick="ArchiveAll">Ja, archivieren</button>
                <button class="btn btn-secondary" @onclick="() => Confirm = false">Abbrechen</button>
            </div>
        }
        
        </div>
    </div>
@if (Rows == null)
{
    <p>Lade...</p>
}
else if (!Rows.Any())
{
    <p>Keine Stunden zum Archivieren gefunden.</p>
}
else
{<div class="table-responsive">
    <table>
        <thead>
            <tr>
                <th>Nutzer</th>
                <th class="text-right">Aktuelle Stunden</th>
                <th class="text-right">Bereits archiviert</th>
                <th class="text-right">Neu gesamt</th>
                <th class="text-right">Aktion</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Rows)
            {
                <tr>
                    <td>@r.User.Name</td>
                    <td class="text-right">@r.CurrentHours.ToString("0.0")</td>
                    <td class="text-right">@r.User.ArchivedHours.ToString("0.0")</td>
                    <td class="text-right">@((r.User.ArchivedHours + r.CurrentHours).ToString("0.0"))</td>
                    <td class="text-right">
                        <button class="btn secondary" @onclick="() => ArchiveRow(r)">Archivieren</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    </div>
}
</div>

<div class="card">
    <h3>Podien nachtragen</h3>
    <p>Berechnet für einen Zeitraum die Top 3 anhand der vorhandenen TimeEntries und trägt fehlende Jahres- und permanente Podien ein.</p>

    <div class="event-grid">
        <div>
            <label>Von</label>
            <input type="date" class="form-control" @bind="PodiumFrom" />
        </div>
        <div>
            <label>Bis</label>
            <input type="date" class="form-control" @bind="PodiumTo" />
        </div>
        <div class="d-flex align-items-end">
            <button class="btn btn-primary" disabled="@PodiumBackfillRunning" @onclick="BackfillPodiums">
                @(PodiumBackfillRunning ? "Berechne..." : "Podien eintragen")
            </button>
        </div>
    </div>

    @if (PodiumBackfillResult is not null)
    {
        <div class="mt-3 d-flex flex-wrap gap-2">
            <span class="badge text-bg-light">Jahr: @PodiumBackfillResult.ArchiveYear</span>
            <span class="badge text-bg-light">Gewertete Nutzer: @PodiumBackfillResult.RankedUsers</span>
            <span class="badge text-bg-success">Neue Jahres-Podien: @PodiumBackfillResult.AwardedYearPodiums</span>
            <span class="badge text-bg-success">Neue permanente Podien: @PodiumBackfillResult.AwardedPermanentPodiums</span>
        </div>
    }
</div>

@code {
    private List<RowModel>? Rows;
    bool Confirm = false;
    private DateTime PodiumFrom = new(DateTime.Today.Year, 1, 1);
    private DateTime PodiumTo = DateTime.Today;
    private bool PodiumBackfillRunning;
    private TimeEntryService.PodiumBackfillResult? PodiumBackfillResult;

    protected override async Task OnInitializedAsync()
    {
        var users = await Uservice.GetAllAsync();
        var entries = await TEservice.GetAllNotArchivedEntriesAsync();

        Rows = users.Select(u =>
        {
            var cur = entries
                            .Where(e => e.UserId == u.Id)
                            .Sum(e => (e.DurationHours));
            cur+= u.BonusHours;
            return new RowModel
            {
                User = u,
                CurrentHours = cur??0
            };
        })
        .Where(r => r.CurrentHours > 0.0)
        .OrderByDescending(r => r.CurrentHours)
        .ToList();
    }


    private class RowModel
    {
        public User User { get; set; } = default!;
        public double CurrentHours { get; set; }
    }
    private TimeEntryService.ArchiveResult? Result;

    private async Task ArchiveRow(RowModel r){
        await TEservice.ArchiveUserHoursAsync(r.User);
        StateHasChanged();
        Toasts.ShowSuccess("User Archiviert",$" Es wurden {r.CurrentHours.ToString("F2")} bei {r.User.Name} archiviert.");
    }
    private async Task ArchiveAll()
    {
        Result = await TEservice.ArchiveAllUsersAsync();
        StateHasChanged();
        Toasts.ShowSuccess("Alle User Archiviert",$"Es wurden insgesamt {Result.TotalHours.ToString("F2")}h \nbei {Result.TotalEntries} Einträgen archviert");
    }

    private async Task BackfillPodiums()
    {
        PodiumBackfillRunning = true;
        try
        {
            PodiumBackfillResult = await TEservice.BackfillPodiumsAsync(PodiumFrom, PodiumTo);
            Toasts.ShowSuccess(
                "Podien eingetragen",
                $"Jahres-Podien: {PodiumBackfillResult.AwardedYearPodiums}, permanente Podien: {PodiumBackfillResult.AwardedPermanentPodiums}");
        }
        catch (Exception ex)
        {
            Toasts.ShowError("Podien konnten nicht berechnet werden", ex.Message);
        }
        finally
        {
            PodiumBackfillRunning = false;
        }
    }



    

}
