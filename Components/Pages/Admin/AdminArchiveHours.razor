@page "/admin/archive"
@using Microsoft.EntityFrameworkCore
@layout AdminLayout
@rendermode InteractiveServer

@inject UserService Uservice
@inject TimeEntryService TEservice


<h2>Stunden archivieren</h2>

<div class="card">
    <div class="Event-grid">
        <div>
        <p>Hier kannst du die seit dem letzten Archiv gesammelten Stunden der Nutzer endgültig verbuchen.</p>
        </div>
        <div>
        </div>
        <div>
        @if (!Confirm)
        {
            <button class="btn btn-danger" @onclick="() => Confirm = true">Alle Nutzer archivieren</button>
        }
        else
        {
            <div>
                <strong>Bist du sicher?</strong><br />
                <button class="btn btn-success" @onclick="ArchiveAll">Ja, archivieren</button>
                <button class="btn btn-secondary" @onclick="() => Confirm = false">Abbrechen</button>
            </div>
        }
        
        </div>
        @if (Result != null)
{
    <div class="alert alert-success" style="margin-top:1rem;">
        Archiviert: @Result.TotalEntries Einträge  
        <br />
        Summe: @Result.TotalHours Stunden
    </div>
}
    </div>
@if (Rows == null)
{
    <p>Lade�</p>
}
else if (!Rows.Any())
{
    <p>Keine Stunden zum Archivieren gefunden.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Nutzer</th>
                <th class="text-right">Aktuelle Stunden</th>
                <th class="text-right">Bereits archiviert</th>
                <th class="text-right">Neu gesamt</th>
                <th class="text-right">Aktion</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Rows)
            {
                <tr>
                    <td>@r.User.Name</td>
                    <td class="text-right">@r.CurrentHours.ToString("0.0")</td>
                    <td class="text-right">@r.User.ArchivedHours.ToString("0.0")</td>
                    <td class="text-right">@(r.User.ArchivedHours + r.CurrentHours).ToString("0.0")</td>
                    <td class="text-right">
                        <button class="btn secondary" @onclick="() => ArchiveRow(r)">Archivieren</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
</div>

@code {
    private List<RowModel>? Rows;
    bool Confirm = false;

    protected override async Task OnInitializedAsync()
    {
        var users = await Uservice.GetAllAsync();
        var entries = await TEservice.GetAllNotArchivedEntriesAsync();

        Rows = users.Select(u =>
        {
            var cur = entries
    .Where(e => e.UserId == u.Id)
    .Sum(e => (e.CheckOut!.Value - e.CheckIn!.Value).TotalHours);

            return new RowModel
            {
                User = u,
                CurrentHours = cur
            };
        })
        .Where(r => r.CurrentHours > 0.0)
        .OrderByDescending(r => r.CurrentHours)
        .ToList();
    }


    private class RowModel
    {
        public User User { get; set; } = default!;
        public double CurrentHours { get; set; }
    }
    private TimeEntryService.ArchiveResult? Result;

    private async Task ArchiveRow(RowModel r){
        await TEservice.ArchiveUserHoursAsync(r.User);
        StateHasChanged();
    }
    private async Task ArchiveAll()
    {
        Result = await TEservice.ArchiveAllUsersAsync();
        StateHasChanged();
    }


    

}