@page "/user/login"
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@inject NavigationManager Nav
@inject AuthStateProvider Auth


<h2>Worktrack Login</h2>

<div class="card" style="max-width: 420px; margin: 2rem auto;">
    <EditForm Model="@Model" OnValidSubmit="@HandleLogin" FormName="Login">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <AntiforgeryToken />

        <label>Secret Code</label>
        <InputText @bind-value="Model.SecretCode" />

        @if (!string.IsNullOrEmpty(Error))
        {
            <p style="color: red; margin-top: 1rem;">@Error</p>
        }

        <button type="submit" class="btn mt-4">Login</button>
    </EditForm>
</div>

@code {
    [SupplyParameterFromForm] 
    private LoginModel Model { get; set; } = new();
    private string? Error;

    private async Task HandleLogin()
    {
        var user = await UService.ValidateSecretCodeAsync(Model.SecretCode);
        
        if (user is null)
        {
            Error = "Invalid code. Please try again.";
            return;
        }
        await Auth.SignInAsync(user.Name,user.Role,user.Id);
        Console.WriteLine("State gesetzt: " + user?.Name);
        //Logger.LogInformation("Log In from: {code}",user.Name);
        Nav.NavigateTo("/user/dashboard", forceLoad: true);
    }
     public class LoginModel
    {
       
        public string SecretCode { get; set; } = "";
    }
}