@page "/user/login"
@inject NavigationManager Nav
@inject Worktrack.Data.AppDbContext Db

@inject ILogger<Login> Logger
@inject AppState State

@rendermode InteractiveServer




<h2>Worktrack Login</h2>

<div class="card" style="max-width: 420px; margin: 2rem auto;">
    <EditForm Model="@Model" OnValidSubmit="@HandleLogin" FormName="Login">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <label>Secret Code</label>
        <InputText @bind-Value="Model.SecretCode" />

        @if (!string.IsNullOrEmpty(Error))
        {
            <p style="color: red; margin-top: 1rem;">@Error</p>
        }

        <button type="submit" class="btn mt-4">Login</button>
    </EditForm>
</div>

@code {
    private LoginModel Model = new();
    private string? Error;

    private async Task HandleLogin()
    {
        var user = await Db.Users
            .FirstOrDefaultAsync(u => u.SecretCode.Trim() == Model.SecretCode.Trim().ToUpper());
        
        Console.WriteLine(Model.SecretCode);
        if (user == null)
        {
            Error = "Invalid code. Please try again.";
            return;
        }
        State.CurrentUser=user;
        Console.WriteLine("State gesetzt: " + State.CurrentUser?.Name);
        //Logger.LogInformation("Log In from: {code}",user.Name);
        Nav.NavigateTo($"/user/dashboard?code={user.SecretCode}", forceLoad: true);
    }

    public class LoginModel
    {
        public string SecretCode { get; set; } = "";
    }
}